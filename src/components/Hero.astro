---
import { getSystemConfig } from '../lib/firebase/config';
import { db } from '../lib/firebase/client';
import { collection, getDocs, query, where, orderBy, limit } from 'firebase/firestore';

const config = await getSystemConfig();
const resumeUrl = config.resumeUrl;

// Fetch primary skills for the Hero Halo
let heroTech = [];
const TECH_MAP: Record<string, { icon: string; color: string }> = {
  'ReactTS': { icon: 'react', color: '61DAFB' },
  'NextJS': { icon: 'nextdotjs', color: 'FFFFFF' },
  'Astro': { icon: 'astro', color: 'FF5D01' },
  'TypeScript': { icon: 'typescript', color: '3178C6' },
  'JavaScript': { icon: 'javascript', color: 'F7DF1E' },
  'VueJS': { icon: 'vuedotjs', color: '4FC08D' },
  'Python': { icon: 'python', color: '3776AB' },
  'Java': { icon: 'java', color: 'ED8B00' },
  'Supabase': { icon: 'supabase', color: '3ECF8E' },
  'PostgreSQL': { icon: 'postgresql', color: '4169E1' },
  'MySQL': { icon: 'mysql', color: '4479A1' },
  'Cloudflare': { icon: 'cloudflare', color: 'F38020' },
  'Nginx': { icon: 'nginx', color: '009639' },
  'Tailscale': { icon: 'tailscale', color: '5D46E3' },
  'HTML/CSS': { icon: 'html5', color: 'E34F26' }
};

// Preset randomized coordinates to avoid ASCII art collision
const POSITIONS = [
  { x: -280, y: -160 }, { x: 120, y: -220 }, { x: -160, y: -240 },
  { x: 350, y: -100 }, { x: 260, y: 160 }, { x: -320, y: 40 },
  { x: -120, y: 260 }, { x: 380, y: 100 }, { x: -300, y: -80 },
  { x: 180, y: 240 }, { x: 300, y: -200 }, { x: -220, y: 160 }
];

try {
  if (import.meta.env.PUBLIC_FIREBASE_API_KEY) {
    const q = query(
      collection(db, 'skills'), 
      orderBy('order', 'asc')
    );
    const snapshot = await getDocs(q);
    
    // Filter for primary skills in memory to avoid needing a composite index
    const primarySkills = snapshot.docs
      .map(doc => doc.data())
      .filter(s => s.level === 'primary')
      .slice(0, POSITIONS.length);

    heroTech = primarySkills.map((data, index) => {
      const mapping = TECH_MAP[data.name] || { icon: 'code', color: 'FFFFFF' };
      return {
        name: data.name,
        ...mapping,
        ...POSITIONS[index],
        delay: `${(index * 0.1).toFixed(1)}s`
      };
    });
  }
} catch (error) {
  console.error("Hero tech fetch failed:", error);
}
