---
import { getSystemConfig } from '../lib/firebase/config';

const config = await getSystemConfig();
const resumeUrl = config.resumeUrl;
---

<section id="hero" class="min-h-screen flex flex-col justify-center border-b border-system-border bg-obsidian pt-16">
  <div class="p-5 md:p-8 py-12 md:py-16 flex-grow flex flex-col justify-center items-center">
    <div class="max-w-6xl w-full">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
        
        <!-- Main Content -->
        <div class="lg:col-span-8 space-y-8">
          <div class="space-y-4">
            <div class="flex gap-2 text-binary-green mb-4 text-xs sm:text-sm animate-on-scroll">
              <span class="font-bold">❯</span>
              <span class="text-text-muted">cat ~/bio/intro.md</span>
            </div>
            
            <h1 class="text-text-primary text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold uppercase tracking-tighter leading-none animate-on-scroll">
              Christian John Legaspi
            </h1>
            
            <p class="text-text-muted text-base sm:text-lg md:text-xl max-w-xl leading-relaxed animate-on-scroll">
              <span class="text-binary-green">Full Stack Developer</span> & <span class="text-caution-yellow">CS Student</span>. Building high-density digital systems with precision and craft.
            </p>
            
            <div class="flex flex-wrap gap-4 pt-4 animate-on-scroll">
              <a href="#projects" class="group px-4 py-2 bg-binary-green text-obsidian text-xs sm:text-sm font-bold uppercase tracking-widest hover:brightness-110 transition-all flex items-center gap-2">
                ./view_projects.sh
              </a>
              <a href={resumeUrl} target="_blank" class="px-4 py-2 border border-system-border text-text-dim text-xs sm:text-sm font-bold uppercase tracking-widest hover:border-binary-green hover:text-binary-green transition-all flex items-center gap-2">
                <span>📄</span> Get Resume
              </a>
            </div>
          </div>

          <!-- Decorative Terminal Sidebar -->
          <div class="hidden lg:block w-64 space-y-4 animate-on-scroll stagger-1">
            <div class="border border-system-border bg-neutral-surface p-4 space-y-3 font-mono">
              <div class="flex justify-between items-center border-b border-system-border pb-2">
                <span class="text-text-dim text-[10px] uppercase tracking-widest">File System</span>
                <span class="text-binary-green text-[10px]">RW</span>
              </div>
              <div class="space-y-1 text-xs">
                <a href={resumeUrl} target="_blank" class="text-text-muted hover:text-binary-green hover:underline decoration-dashed underline-offset-4 transition-colors block">
                  -rw-r--r--  resume.pdf
                </a>
                <span class="text-text-dim block">drwxr-xr-x  projects/</span>
                <span class="text-text-dim block">drwxr-xr-x  about/</span>
              </div>
              
              <div class="pt-2">
                <div class="bg-neutral-layer border border-system-border aspect-[3/4] relative overflow-hidden group">
                  <div class="absolute inset-0 bg-obsidian/40 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity z-10">
                    <span class="text-binary-green text-[10px] font-bold tracking-widest uppercase">Open Terminal View</span>
                  </div>
                  <div class="p-2 border-b border-system-border bg-neutral-layer flex justify-between items-center">
                    <div class="flex gap-1">
                      <div class="w-1.5 h-1.5 rounded-full bg-system-border"></div>
                      <div class="w-1.5 h-1.5 rounded-full bg-system-border"></div>
                    </div>
                    <span class="text-text-dim font-mono text-[10px]">previewing: {resumeUrl.split('/').pop()}</span>
                  </div>
                  <iframe src={`${resumeUrl}#toolbar=0&navpanes=0&scrollbar=0&view=FitH`} class="w-full h-[calc(100%-28px)] border-none bg-neutral-100" title="Resume preview"></iframe>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Telemetry Data (Desktop) -->
        <div class="lg:col-span-4 space-y-6 hidden lg:block">
          <div class="border border-system-border bg-neutral-surface p-6 font-mono space-y-4 animate-on-scroll stagger-2">
            <h3 class="text-caution-yellow text-xs font-bold uppercase tracking-widest border-b border-system-border pb-2">System Status</h3>
            <div class="space-y-3">
              <div class="space-y-1">
                <div class="flex justify-between text-[10px] uppercase">
                  <span class="text-text-dim">Uptime</span>
                  <span class="text-binary-green">99.98%</span>
                </div>
                <div class="h-1 bg-neutral-layer overflow-hidden">
                  <div class="h-full bg-binary-green w-[99.98%]"></div>
                </div>
              </div>
              <div class="space-y-1">
                <div class="flex justify-between text-[10px] uppercase">
                  <span class="text-text-dim">Latency</span>
                  <span class="text-binary-green">24ms</span>
                </div>
                <div class="h-1 bg-neutral-layer overflow-hidden">
                  <div class="h-full bg-binary-green w-[24%]"></div>
                </div>
              </div>
              <div class="space-y-1">
                <div class="flex justify-between text-[10px] uppercase">
                  <span class="text-text-dim">Core Load</span>
                  <span class="text-caution-yellow">Optimized</span>
                </div>
                <div class="h-1 bg-neutral-layer overflow-hidden">
                  <div class="h-full bg-caution-yellow w-[65%]"></div>
                </div>
              </div>
            </div>
            <div class="pt-2 text-[10px] text-text-dim leading-tight">
              PROD_READY_ENVIRONMENT<br/>
              NODE_VERSION: v20.x<br/>
              SSR_ENABLED: FALSE
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>
