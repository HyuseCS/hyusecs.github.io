---
import { getSystemConfig } from '../lib/firebase/config';

const config = await getSystemConfig();
const resumeUrl = config.resumeUrl;
---

<section id="hero" class="min-h-screen flex flex-col justify-center border-b border-system-border bg-obsidian pt-16">
  <div class="p-5 md:p-8 py-12 md:py-16 flex-grow flex flex-col justify-center items-center">
    <div class="max-w-6xl w-full flex flex-col lg:flex-row items-center lg:items-start gap-12 lg:gap-16">
      
      <!-- Left Column: System Info (fastfetch style) -->
      <div class="w-full lg:w-1/2 space-y-6 animate-on-scroll">
        <!-- Command Prompt -->
        <div class="flex items-center gap-2 text-binary-green text-xs sm:text-sm">
          <span class="font-bold">вқҜ</span>
          <span class="text-text-muted">cat ~/bio/intro.md</span>
        </div>

        <!-- System Metadata -->
        <div class="space-y-2 font-mono text-sm sm:text-base">
          <div class="flex border-b border-system-border pb-2 mb-4 w-32 opacity-50"></div>
          
          <div class="flex gap-4">
            <span class="text-binary-green font-bold min-w-[80px]">USER:</span>
            <span class="text-text-primary">CJ || Hyuse</span>
          </div>
          <div class="flex gap-4">
            <span class="text-binary-green font-bold min-w-[80px]">ROLE:</span>
            <span class="text-text-muted">Full Stack Developer</span>
          </div>
          <div class="flex gap-4">
            <span class="text-binary-green font-bold min-w-[80px]">EDU:</span>
            <span class="text-caution-yellow">CS Student</span>
          </div>
          <div class="flex gap-4 pt-2">
            <span class="text-binary-green font-bold min-w-[80px]">BIO:</span>
            <p class="text-text-dim max-w-md leading-relaxed">
              Building high-density digital systems with precision and craft.
            </p>
          </div>
        </div>

        <!-- Actions -->
        <div class="flex flex-wrap gap-4 pt-4">
          <a href="#projects" class="group px-6 py-3 bg-binary-green text-obsidian text-xs font-bold uppercase tracking-widest hover:brightness-110 transition-all flex items-center gap-2">
            ./view_projects.sh
          </a>
          
          <div class="relative group">
            <a href={resumeUrl} target="_blank" class="px-6 py-3 border border-system-border text-text-dim text-xs font-bold uppercase tracking-widest hover:border-binary-green hover:text-binary-green transition-all flex items-center gap-2">
              <span>рҹ“„</span> Get Resume
            </a>
            
            <!-- Floating Preview Card -->
            <div class="absolute bottom-full mb-6 left-1/2 -translate-x-1/2 lg:left-0 lg:translate-x-0 w-64 md:w-80 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 z-50 pointer-events-none group-hover:pointer-events-auto">
              <div class="border border-system-border bg-neutral-surface p-2 shadow-2xl space-y-2 font-mono">
                <div class="p-2 border-b border-system-border bg-neutral-layer flex justify-between items-center">
                  <div class="flex gap-1">
                    <div class="w-1.5 h-1.5 rounded-full bg-system-border"></div>
                    <div class="w-1.5 h-1.5 rounded-full bg-system-border"></div>
                  </div>
                  <span class="text-text-dim font-mono text-[9px]">previewing: {resumeUrl.split('/').pop()}</span>
                </div>
                <div class="bg-neutral-layer border border-system-border aspect-[3/4] relative overflow-hidden">
                  <iframe src={`${resumeUrl}#toolbar=0&navpanes=0&scrollbar=0&view=FitH`} class="w-full h-full border-none bg-neutral-100" title="Resume preview"></iframe>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Right Column: ASCII Logo + Floating Tech -->
      <div class="w-full lg:w-1/2 flex justify-center lg:justify-end animate-on-scroll relative group" aria-label="Christian John Legaspi">
        <!-- Mobile Name (visible only on mobile) -->
        <h1 class="lg:hidden text-text-primary text-4xl sm:text-5xl font-bold uppercase tracking-tighter leading-none text-center">
          Christian John Legaspi
        </h1>
        
        <!-- Desktop ASCII Art (hidden on mobile) -->
        <div class="hidden lg:block relative">
          <!-- Floating Logos -->
          <div class="absolute -top-10 -left-16 animate-float opacity-30 group-hover:opacity-100 transition-opacity duration-500 select-none pointer-events-none" style="animation-duration: 7s;">
            <img src="https://cdn.simpleicons.org/react/27c93f" class="w-8 h-8 opacity-80" alt="React" />
          </div>
          <div class="absolute top-1/4 -left-24 animate-float opacity-30 group-hover:opacity-100 transition-opacity duration-500 select-none pointer-events-none" style="animation-duration: 9s; animation-delay: -2s;">
            <img src="https://cdn.simpleicons.org/astro/ffffff" class="w-8 h-8 opacity-80" alt="Astro" />
          </div>
          <div class="absolute -bottom-6 -left-14 animate-float opacity-30 group-hover:opacity-100 transition-opacity duration-500 select-none pointer-events-none" style="animation-duration: 8s; animation-delay: -4s;">
            <img src="https://cdn.simpleicons.org/typescript/27c93f" class="w-8 h-8 opacity-80" alt="TypeScript" />
          </div>
          <div class="absolute -top-14 right-1/4 animate-float opacity-30 group-hover:opacity-100 transition-opacity duration-500 select-none pointer-events-none" style="animation-duration: 10s; animation-delay: -1s;">
            <img src="https://cdn.simpleicons.org/firebase/ffbd2e" class="w-8 h-8 opacity-80" alt="Firebase" />
          </div>
          <div class="absolute top-1/2 -right-20 animate-float opacity-30 group-hover:opacity-100 transition-opacity duration-500 select-none pointer-events-none" style="animation-duration: 11s; animation-delay: -5s;">
            <img src="https://cdn.simpleicons.org/supabase/27c93f" class="w-8 h-8 opacity-80" alt="Supabase" />
          </div>
          <div class="absolute -bottom-10 right-10 animate-float opacity-30 group-hover:opacity-100 transition-opacity duration-500 select-none pointer-events-none" style="animation-duration: 9s; animation-delay: -3s;">
            <img src="https://cdn.simpleicons.org/nodedotjs/27c93f" class="w-8 h-8 opacity-80" alt="Node.js" />
          </div>

          <pre class="text-binary-green font-mono text-[0.8rem] xl:text-[0.9rem] leading-none select-none text-right">
 в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•—  в–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв•—   в–Ҳв–Ҳв•—
