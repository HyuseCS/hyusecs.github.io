<section id="hero" class="min-h-[calc(100vh-4rem-30px)] md:snap-start scroll-mt-14 flex flex-col justify-center border-b border-[#333] bg-[#0c0c0c] relative overflow-hidden">
  <!-- Animated Grid Background -->
  <div class="absolute inset-0 hero-grid-bg pointer-events-none" aria-hidden="true"></div>
  


  <div class="p-5 md:p-8 flex-grow flex flex-col justify-center items-center relative z-10">
    <div class="space-y-4 max-w-4xl w-full animate-on-scroll">
      <div class="space-y-4">
        <div class="flex gap-2 text-[#27c93f] items-center">
          <span class="font-bold" aria-hidden="true">❯</span>
          <span id="hero-typewriter" class="text-[#d4d4d4] font-mono border-r-2 border-[#d4d4d4] pr-1 min-h-[1.5rem]"></span>
        </div>
        
        <script>
          document.addEventListener('DOMContentLoaded', () => {
             const target = document.getElementById("hero-typewriter");
             if(!target) return;
             
             const textToType = "whoami";
             let index = 0;

             // Blink the cursor via border color toggle
             setInterval(() => {
               target.style.borderColor = target.style.borderColor === "transparent" ? "#d4d4d4" : "transparent";
             }, 500);

             // Execute typewriter with slight delay for effect
             setTimeout(() => {
               const typingInterval = setInterval(() => {
                 target.textContent += textToType.charAt(index);
                 index++;
                 if (index >= textToType.length) {
                   clearInterval(typingInterval);
                 }
               }, 120);
             }, 400);
          });
        </script>
        
        <div class="pl-2 sm:pl-4 py-6">
          <h1 class="text-3xl sm:text-5xl lg:text-6xl font-bold text-white mb-4 sm:mb-6 animate-on-scroll stagger-1">
            Christian John Legaspi
          </h1>
          <p class="text-sm sm:text-base md:text-lg text-[#888] max-w-2xl leading-relaxed animate-on-scroll stagger-2">
            <span class="text-[#27c93f]">const</span> role = <span class="text-[#ffbd2e]">"Full Stack Developer"</span>;
            <br /><br />
            Computer Science student at USTP and Full Stack Developer based in Cagayan de Oro. Building robust software solutions and web applications.
          </p>
        </div>

        <div class="animate-on-scroll stagger-3">
          <div class="flex gap-2 text-[#27c93f] pt-4">
            <span class="font-bold" aria-hidden="true">❯</span>
            <span class="text-[#d4d4d4]">ls -a ./highlights</span>
          </div>

          <div class="pl-2 sm:pl-4 flex flex-col sm:flex-row flex-wrap gap-4 sm:gap-6 pt-4 text-sm sm:text-base">
            <a href="#projects" class="text-[#27c93f] hover:text-white hover:underline decoration-dashed underline-offset-4 transition-colors">
              drwxr-xr-x  projects/
            </a>
            <a href="#contact" class="text-[#ffbd2e] hover:text-white hover:underline decoration-dashed underline-offset-4 transition-colors">
              -rw-r--r--  contact.sh
            </a>
            
            <div class="relative group cursor-pointer w-fit">
              <a href="/LEGASPI_RESUME.pdf" target="_blank" class="text-[#d4d4d4] hover:text-[#27c93f] hover:underline decoration-dashed underline-offset-4 transition-colors block">
                -rw-r--r--  resume.pdf
              </a>
              
              <!-- PDF Hover Panel (Desktop Only) -->
              <div class="absolute bottom-full left-0 md:-left-24 mb-4 w-[320px] h-[400px] sm:w-[600px] sm:h-[800px] bg-[#1a1a1a] border border-[#333] shadow-2xl opacity-0 pointer-events-none group-hover:opacity-100 group-hover:pointer-events-auto transition-all duration-300 z-50 rounded-sm overflow-hidden hidden md:block origin-bottom-left scale-95 group-hover:scale-100">
                <div class="bg-[#1e1e1e] flex items-center justify-between px-3 py-1.5 border-b border-[#333]">
                  <span class="text-[#888] font-mono text-[10px]">previewing: LEGASPI_RESUME.pdf</span>
                  <span class="text-[#ffbd2e] font-mono text-[10px] flex items-center gap-2">
                    <span class="w-2 h-2 rounded-full bg-[#ffbd2e] animate-pulse" aria-hidden="true"></span> Rendering
                  </span>
                </div>
                <iframe src="/LEGASPI_RESUME.pdf#toolbar=0&navpanes=0&scrollbar=0&view=FitH" class="w-full h-[calc(100%-28px)] border-none bg-neutral-100" title="Resume preview"></iframe>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>