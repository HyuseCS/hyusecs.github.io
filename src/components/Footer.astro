---
const currentYear = new Date().getFullYear();
---

<footer class="bg-[#111] text-[#555] h-10 border-t border-[#333] font-mono flex items-center justify-between px-6 text-[10px] sm:text-xs shrink-0 z-50 mt-auto">
  <div class="flex items-center gap-4">
    <div class="flex items-center gap-2">
      <span class="text-[#27c93f]">●</span>
      <span class="text-[#d4d4d4] uppercase tracking-tighter">System Online</span>
    </div>
    <div class="hidden sm:block h-4 w-[1px] bg-[#333]"></div>
    <div class="hidden sm:flex text-[#555]">
      &copy; {currentYear} CJ 
    </div>
  </div>

  <div class="flex items-center gap-6">
    <div class="hidden lg:flex gap-6">
      <div class="flex gap-2">
        <span class="text-[#333]">CPU</span>
        <span class="text-[#888]">Normal</span>
      </div>
      <div class="flex gap-2">
        <span class="text-[#333]">MEM</span>
        <span class="text-[#888]">Stable</span>
      </div>
    </div>
  </div>
</footer>
