---
const currentYear = new Date().getFullYear();
---

<footer class="fixed bottom-0 left-0 w-full bg-[#111] text-[#777] h-[30px] sm:h-8 border-t border-[#333] font-mono flex items-center justify-between px-4 sm:px-6 text-[9px] sm:text-[10px] z-[100]" role="contentinfo">
  <div class="flex items-center gap-4">
    <div class="flex items-center gap-2">
      <span class="text-[#27c93f]" aria-hidden="true">●</span>
      <span class="text-[#d4d4d4] uppercase tracking-tighter">System Online</span>
    </div>
    <div class="hidden sm:block h-4 w-[1px] bg-[#333]" aria-hidden="true"></div>
    <div class="hidden sm:flex text-[#777]">
      &copy; {currentYear} CJ 
    </div>
  </div>

  <div class="flex items-center gap-6">
    <div class="hidden lg:flex gap-6">
      <div class="flex gap-2">
        <span class="text-[#555]">CPU</span>
        <span class="text-[#888]">Normal</span>
      </div>
      <div class="flex gap-2">
        <span class="text-[#555]">MEM</span>
        <span class="text-[#888]">Stable</span>
      </div>
    </div>
  </div>
</footer>
