---
const frontendSkills = [
  { name: 'ReactTS', level: 'primary' },
  { name: 'NextJS', level: 'primary' },
  { name: 'VueJS', level: 'familiar' },
  { name: 'Astro', level: 'familiar' },
  { name: 'HTML/CSS', level: 'primary' },
  { name: 'JavaScript', level: 'primary' },
];

const backendSkills = [
  { name: 'Python', level: 'primary' },
  { name: 'Java', level: 'primary' },
  { name: 'C++', level: 'familiar' },
  { name: 'JavaFX', level: 'familiar' },
  { name: 'Tkinter/CustomTkinter', level: 'familiar' },
];

const infraSkills = [
  { name: 'Supabase', level: 'primary' },
  { name: 'MariaDB', level: 'familiar' },
  { name: 'MySQL', level: 'primary' },
  { name: 'PostgreSQL', level: 'primary' },
  { name: 'Debian/Ubuntu Server', level: 'familiar' },
  { name: 'Nginx', level: 'familiar' },
  { name: 'Cloudflare', level: 'familiar' },
  { name: 'Tailscale', level: 'familiar' },
];

function getProficiencyBar(level: string) {
  return level === 'primary' ? '████░' : '███░░';
}
---

<section id="skills" class="min-h-[calc(100vh-4rem-30px)] scroll-mt-14 flex flex-col justify-center border-b border-system-border bg-obsidian">
  <div class="p-5 md:p-8 py-12 md:py-16 flex-grow flex flex-col justify-center items-center">
    <div class="max-w-4xl w-full">
      <div class="flex gap-2 text-binary-green mb-6 md:mb-8 text-sm sm:text-base animate-on-scroll">
        <span class="font-bold" aria-hidden="true">❯</span>
        <span class="text-text-muted break-all">python fetch_skills.py --format=blocks</span>
      </div>

      <h2 class="sr-only">Technical Skills</h2>

      <div class="pl-2 sm:pl-4 grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-10">
        <div class="space-y-4 animate-on-scroll stagger-1">
          <h3 class="text-caution-yellow text-xs sm:text-sm font-bold uppercase tracking-widest border-b border-system-border pb-2">Frontend</h3>
          <div class="flex flex-wrap gap-2 pt-2">
            {frontendSkills.map(skill => (
              <span class={`group px-2 sm:px-3 py-1.5 bg-surface-high border border-system-border text-xs sm:text-sm text-text-muted hover:border-binary-green hover:bg-binary-green/10 transition-colors cursor-default relative`}>
                {skill.name}
                <span class={`ml-1.5 proficiency-bar active-bar ${skill.level === 'primary' ? 'text-binary-green' : 'text-text-deemphasized'} opacity-0 transition-opacity duration-300`} aria-label={`${skill.level} proficiency`}>{getProficiencyBar(skill.level)}</span>
              </span>
            ))}
          </div>
        </div>

        <div class="space-y-4 animate-on-scroll stagger-2">
          <h3 class="text-caution-yellow text-xs sm:text-sm font-bold uppercase tracking-widest border-b border-system-border pb-2">Backend & Desktop</h3>
          <div class="flex flex-wrap gap-2 pt-2">
            {backendSkills.map(skill => (
              <span class={`group px-2 sm:px-3 py-1.5 bg-surface-high border border-system-border text-xs sm:text-sm text-text-muted hover:border-binary-green hover:bg-binary-green/10 transition-colors cursor-default relative`}>
                {skill.name}
                <span class={`ml-1.5 proficiency-bar active-bar ${skill.level === 'primary' ? 'text-binary-green' : 'text-text-deemphasized'} opacity-0 transition-opacity duration-300`} aria-label={`${skill.level} proficiency`}>{getProficiencyBar(skill.level)}</span>
              </span>
            ))}
          </div>
        </div>

        <div class="space-y-4 md:col-span-2 animate-on-scroll stagger-3">
          <h3 class="text-caution-yellow text-xs sm:text-sm font-bold uppercase tracking-widest border-b border-system-border pb-2">Databases & Infrastructure</h3>
          <div class="flex flex-wrap gap-2 pt-2">
            {infraSkills.map(skill => (
              <span class={`group px-2 sm:px-3 py-1.5 bg-layer-1 border border-system-border text-xs sm:text-sm ${skill.level === 'primary' ? 'text-text-muted hover:border-binary-green' : 'text-text-dim hover:text-text-muted hover:border-text-dim'} transition-colors cursor-default relative`}>
                {skill.name}
                <span class={`ml-1.5 proficiency-bar active-bar ${skill.level === 'primary' ? 'text-binary-green' : 'text-text-deemphasized'} opacity-0 transition-opacity duration-300`} aria-label={`${skill.level} proficiency`}>{getProficiencyBar(skill.level)}</span>
              </span>
            ))}
          </div>
        </div>
      </div>

      <div class="mt-6 pl-2 sm:pl-4 flex items-center gap-4 text-[10px] text-text-deemphasized font-mono animate-on-scroll stagger-3">
        <span class="flex items-center gap-1"><span class="text-binary-green proficiency-bar">████░</span> primary</span>
        <span class="flex items-center gap-1"><span class="text-text-deemphasized proficiency-bar">███░░</span> familiar</span>
      </div>

    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const section = document.getElementById('skills');
    const bars = section?.querySelectorAll('.proficiency-bar.active-bar');

    if (!section || !bars) return;

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          bars.forEach((bar, index) => {
            const htmlBar = bar as HTMLElement;
            setTimeout(() => {
              htmlBar.style.opacity = '1';
              const fullText = htmlBar.textContent || '';
              htmlBar.textContent = '';
              let i = 0;
              const streamInterval = setInterval(() => {
                htmlBar.textContent += fullText.charAt(i);
                i++;
                if (i >= fullText.length) clearInterval(streamInterval);
              }, 80);
            }, 300 + (index * 40));
          });
          observer.unobserve(section);
        }
      });
    }, { threshold: 0.1 });

    observer.observe(section);
  });
</script>