<section id="skills" class="min-h-[calc(100vh-4rem)] snap-start scroll-mt-14 flex flex-col justify-center border-b border-[#333] bg-[#0c0c0c]">
  <div class="p-5 md:p-8 py-12 md:py-16 flex-grow flex flex-col justify-center items-center">
    <div class="max-w-4xl w-full">
      <div class="flex gap-2 text-[#27c93f] mb-6 md:mb-8 text-sm sm:text-base animate-on-scroll">
        <span class="font-bold">❯</span>
        <span class="text-[#d4d4d4] break-all">python fetch_skills.py --format=blocks</span>
      </div>

      <div class="pl-2 sm:pl-4 grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-10">
        <div class="space-y-4 animate-on-scroll stagger-1">
          <h3 class="text-[#ffbd2e] text-xs sm:text-sm font-bold uppercase tracking-widest border-b border-[#333] pb-2">Frontend</h3>
          <div class="flex flex-wrap gap-2 pt-2">
            {['ReactTS', 'NextJS', 'VueJS', 'Astro', 'HTML/CSS', 'JavaScript'].map(skill => (
              <span class="px-2 sm:px-3 py-1.5 bg-[#1e1e1e] border border-[#333] text-xs sm:text-sm text-[#d4d4d4] hover:border-[#27c93f] hover:bg-[#27c93f]/10 transition-colors cursor-default">{skill}</span>
            ))}
          </div>
        </div>

        <div class="space-y-4 animate-on-scroll stagger-2">
          <h3 class="text-[#ffbd2e] text-xs sm:text-sm font-bold uppercase tracking-widest border-b border-[#333] pb-2">Backend & Desktop</h3>
          <div class="flex flex-wrap gap-2 pt-2">
            {['Python', 'Java', 'C++', 'JavaFX', 'Tkinter/CustomTkinter'].map(skill => (
              <span class="px-2 sm:px-3 py-1.5 bg-[#1e1e1e] border border-[#333] text-xs sm:text-sm text-[#d4d4d4] hover:border-[#27c93f] hover:bg-[#27c93f]/10 transition-colors cursor-default">{skill}</span>
            ))}
          </div>
        </div>

        <div class="space-y-4 md:col-span-2 animate-on-scroll stagger-3">
          <h3 class="text-[#ffbd2e] text-xs sm:text-sm font-bold uppercase tracking-widest border-b border-[#333] pb-2">Databases & Infrastructure</h3>
          <div class="flex flex-wrap gap-2 pt-2">
            {['Supabase', 'MariaDB', 'MySQL', 'PostgreSQL', 'Debian/Ubuntu Server', 'Nginx', 'Cloudflare', 'Tailscale'].map(skill => (
              <span class="px-2 sm:px-3 py-1.5 bg-[#111] border border-[#333] text-xs sm:text-sm text-[#888] hover:text-[#d4d4d4] hover:border-[#888] transition-colors cursor-default">{skill}</span>
            ))}
          </div>
        </div>
      </div>
      
      </div>
      
    </div>
  </div>
</section>