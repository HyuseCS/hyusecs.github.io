---
import AssetConfig from './config/AssetConfig.astro';
import ContactConfig from './config/ContactConfig.astro';
import TelemetryConfig from './config/TelemetryConfig.astro';
---

<div id="system-config" class="border border-system-border bg-layer-1 p-8 space-y-10">
  <div class="space-y-2 border-l-2 border-binary-green pl-4">
    <h3 class="text-text-primary text-lg font-black uppercase tracking-tighter flex items-center gap-3">
      <span class="text-binary-green">#</span> System Variables
    </h3>
    <p class="text-text-dim text-[10px] uppercase tracking-[0.2em] font-bold">Global Configuration Clusters</p>
  </div>

  <div class="grid grid-cols-1 gap-8">
    <AssetConfig />
    <ContactConfig />
    <TelemetryConfig />
  </div>
</div>
