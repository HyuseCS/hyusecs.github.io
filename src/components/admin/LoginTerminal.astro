---
---

<div id="login-terminal" class="fixed inset-0 bg-obsidian z-[100] flex items-center justify-center p-4 md:p-8 overflow-y-auto">
  <div class="max-w-md w-full border border-system-border bg-layer-1 font-mono text-sm shadow-[0_0_50px_rgba(0,0,0,0.5)] animate-boot">
    <!-- Terminal Header -->
    <div class="bg-layer-2 border-b border-system-border p-3 flex justify-between items-center">
      <div class="flex gap-2">
        <div class="w-2 h-2 rounded-full bg-red-500/30 border border-red-500/50"></div>
        <div class="w-2 h-2 rounded-full bg-caution-yellow/30 border border-caution-yellow/50"></div>
        <div class="w-2 h-2 rounded-full bg-binary-green/30 border border-binary-green/50"></div>
      </div>
      <div class="flex items-center gap-2">
        <span class="w-1 h-1 bg-binary-green/50 animate-pulse"></span>
        <span class="text-text-dim text-[10px] uppercase tracking-[0.2em] font-bold">Verification Gate</span>
      </div>
    </div>
    
    <div class="p-8 space-y-8">
      <div class="space-y-3">
        <div class="flex gap-2 text-binary-green items-center">
          <span class="font-bold text-xs">❯</span>
          <span class="text-text-muted text-xs uppercase tracking-widest font-bold">systemctl auth --init</span>
        </div>
        <p class="text-text-dim text-xs leading-relaxed">
          Accessing encrypted administrative protocols. Provide valid credentials or GitHub OAuth signature to proceed.
        </p>
      </div>

      <div class="space-y-6">
        <button 
          id="github-login-btn" 
          class="group w-full py-4 bg-white text-obsidian hover:bg-binary-green transition-all uppercase tracking-[0.2em] text-[10px] font-black flex items-center justify-center gap-3 relative overflow-hidden"
        >
          <div class="absolute inset-0 bg-binary-green/10 translate-x-[-100%] group-hover:translate-x-0 transition-transform duration-300"></div>
          <svg class="w-4 h-4 relative z-10" fill="currentColor" viewBox="0 0 24 24"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
          <span class="relative z-10">Sign in with GitHub</span>
        </button>

        <div id="login-error" class="hidden text-red-500 text-[10px] border border-red-500/30 bg-red-500/5 p-3 font-mono leading-relaxed">
          <span class="font-bold">[CRITICAL_ERROR]</span><br/>
          AUTHENTICATION_PROTOCOL_FAILED: IDENTITY_NOT_VERIFIED
        </div>
      </div>
    </div>
    
    <div class="bg-layer-2 border-t border-system-border p-3 text-[9px] text-text-dim flex justify-between font-bold uppercase tracking-widest">
      <div class="flex items-center gap-2">
        <span class="text-binary-green">SSH</span>
        <span class="text-system-border">|</span>
        <span>AES-256</span>
      </div>
      <span id="terminal-status" class="animate-pulse">STATUS: STANDBY</span>
    </div>
  </div>
</div>

<script>
  import { auth } from '../../lib/firebase/client';
  import { GithubAuthProvider, signInWithPopup } from 'firebase/auth';

  const githubBtn = document.getElementById('github-login-btn');
  const errorEl = document.getElementById('login-error');
  const statusEl = document.getElementById('terminal-status');

  githubBtn?.addEventListener('click', async () => {
    const provider = new GithubAuthProvider();
    if (statusEl) statusEl.textContent = 'STATUS: REDIRECTING_TO_GITHUB...';
    if (errorEl) errorEl.classList.add('hidden');
    
    try {
      await signInWithPopup(auth, provider);
    } catch (error) {
      console.error(error);
      if (errorEl) errorEl.classList.remove('hidden');
      if (statusEl) statusEl.textContent = 'STATUS: AUTH_FAILED';
    }
  });
</script>
