---
---

<div id="skill-manager" class="space-y-10 animate-boot">
  <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6 border-l-2 border-caution-yellow pl-6 py-2">
    <div class="space-y-2">
      <h3 class="text-text-primary text-2xl font-black uppercase tracking-tighter flex items-center gap-3">
        <span class="text-caution-yellow">#</span> Skill Repository
      </h3>
      <p class="text-text-dim text-[10px] uppercase tracking-[0.3em] font-bold">Managing technical proficiency modules</p>
    </div>
    <div class="flex gap-4">
      <button 
        id="seed-skills-btn"
        class="py-3 px-6 border border-system-border text-text-dim hover:text-white transition-all text-[10px] uppercase tracking-[0.2em] font-bold"
      >
        Seed Initial Data
      </button>
      <button 
        id="add-skill-btn"
        class="group py-3 px-6 bg-caution-yellow text-obsidian hover:brightness-110 transition-all text-[10px] uppercase tracking-[0.2em] font-black flex items-center gap-3"
      >
        <span class="text-lg leading-none">+</span> Register New Module
      </button>
    </div>
  </div>

  <!-- Loading State -->
  <div id="skills-loading" class="border border-system-border bg-layer-1 p-16 text-center space-y-6">
    <div class="relative inline-block w-12 h-12">
      <div class="absolute inset-0 border-2 border-caution-yellow/20 rounded-full"></div>
      <div class="absolute inset-0 border-2 border-caution-yellow border-t-transparent animate-spin rounded-full"></div>
    </div>
    <p class="text-text-dim text-[10px] uppercase tracking-[0.4em] animate-pulse font-bold">Syncing_Skill_Nodes...</p>
  </div>

  <!-- Empty State -->
  <div id="skills-empty" class="hidden border border-system-border bg-layer-1 p-20 text-center space-y-4">
    <div class="text-text-dim/20 text-5xl font-black">NULL</div>
    <p class="text-text-dim text-xs uppercase tracking-widest">No skill modules detected in the repository.</p>
  </div>

  <!-- Skill List Grouped by Category -->
  <div id="skills-container" class="hidden space-y-12">
    <!-- Frontend -->
    <div class="space-y-4">
      <h4 class="text-binary-green text-[10px] font-bold uppercase tracking-[0.3em] border-b border-system-border pb-2">Frontend_Modules</h4>
      <div id="list-frontend" class="grid grid-cols-1 md:grid-cols-2 gap-3"></div>
    </div>
    <!-- Backend -->
    <div class="space-y-4">
      <h4 class="text-binary-green text-[10px] font-bold uppercase tracking-[0.3em] border-b border-system-border pb-2">Backend_Desktop_Modules</h4>
      <div id="list-backend" class="grid grid-cols-1 md:grid-cols-2 gap-3"></div>
    </div>
    <!-- Infra -->
    <div class="space-y-4">
      <h4 class="text-binary-green text-[10px] font-bold uppercase tracking-[0.3em] border-b border-system-border pb-2">Infra_Database_Modules</h4>
      <div id="list-infra" class="grid grid-cols-1 md:grid-cols-2 gap-3"></div>
    </div>
  </div>
</div>

<!-- Skill Modal -->
<div id="skill-modal" class="hidden fixed inset-0 bg-black z-[200] flex items-center justify-center backdrop-blur-md overflow-y-auto p-4 md:p-12">
  <div class="max-w-xl w-full border border-system-border bg-layer-1 font-mono text-sm shadow-[0_0_100px_rgba(0,0,0,0.9)] animate-boot my-auto">
    <div class="bg-layer-2 border-b border-system-border p-4 flex justify-between items-center">
      <div class="flex items-center gap-3">
        <div class="w-1.5 h-1.5 bg-caution-yellow animate-pulse"></div>
        <span id="s-modal-title" class="text-text-primary uppercase tracking-[0.2em] font-black text-xs">Register Skill Module</span>
      </div>
      <button id="close-skill-modal" class="text-text-dim hover:text-white transition-colors p-1">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
      </button>
    </div>

    <form id="skill-form" class="p-8 space-y-6 max-h-[85vh] overflow-y-auto">
      <input type="hidden" id="skill-id" />

        <div class="space-y-2">
          <label class="text-text-dim block text-[10px] uppercase tracking-widest font-bold">Module Name</label>
          <input type="text" id="s-name" required placeholder="e.g., ReactTS" class="w-full bg-layer-2 border border-system-border p-3 outline-none focus:border-caution-yellow/50 text-text-primary transition-all text-xs" />
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div class="space-y-2">
            <label class="text-text-dim block text-[10px] uppercase tracking-widest font-bold">Category</label>
            <select id="s-category" required class="w-full bg-layer-2 border border-system-border p-3 outline-none focus:border-caution-yellow/50 text-text-primary transition-all text-xs appearance-none">
              <option value="frontend">Frontend</option>
              <option value="backend">Backend & Desktop</option>
              <option value="infra">Infra & Databases</option>
            </select>
          </div>

          <div class="space-y-2">
            <label class="text-text-dim block text-[10px] uppercase tracking-widest font-bold">Proficiency Level</label>
            <select id="s-level" required class="w-full bg-layer-2 border border-system-border p-3 outline-none focus:border-caution-yellow/50 text-text-primary transition-all text-xs appearance-none">
              <option value="primary">Primary (High)</option>
              <option value="familiar">Familiar (Mid)</option>
            </select>
          </div>
        </div>

        <div class="space-y-2">
          <label class="text-text-dim block text-[10px] uppercase tracking-widest font-bold">Sequence Order</label>
          <input type="number" id="s-order" required value="0" class="w-full bg-layer-2 border border-system-border p-3 outline-none focus:border-caution-yellow/50 text-text-primary transition-all text-xs" />
        </div>

        <div class="pt-4 flex flex-col sm:flex-row gap-4">
          <button type="submit" class="flex-grow py-4 bg-caution-yellow text-obsidian uppercase tracking-[0.2em] text-[10px] font-black hover:brightness-110 transition-all">Synchronize Module</button>
          <button type="button" id="cancel-skill-modal" class="py-4 px-8 border border-system-border text-text-dim uppercase tracking-[0.2em] text-[10px] font-black hover:bg-layer-2 transition-all">Abort Action</button>
        </div>
      </form>
    </div>
    </div>
<template id="skill-item-template">
  <div class="skill-item border border-system-border bg-layer-1 p-4 flex justify-between items-center group hover:border-caution-yellow/50 transition-all duration-300">
    <div class="flex items-center gap-3">
      <div class="level-indicator w-1 h-3 transition-colors"></div>
      <span class="skill-name text-text-primary font-bold text-sm tracking-tight"></span>
    </div>
    <div class="flex gap-2">
      <button class="s-edit-btn p-2 border border-system-border text-text-dim hover:text-caution-yellow hover:border-caution-yellow/50 transition-all bg-layer-2" title="Edit Module">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
        </svg>
      </button>
      <button class="s-delete-btn p-2 border border-system-border text-text-dim hover:text-red-500 hover:border-red-500/50 transition-all bg-layer-2" title="Decommission Module">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
        </svg>
      </button>
    </div>
  </div>
</template>

<script>
  import { db } from '../../lib/firebase/client';
  import { collection, getDocs, query, orderBy, addDoc, updateDoc, deleteDoc, doc } from 'firebase/firestore';

  const container = document.getElementById('skills-container');
  const loadingEl = document.getElementById('skills-loading');
  const emptyEl = document.getElementById('skills-empty');
  const modal = document.getElementById('skill-modal');
  const form = document.getElementById('skill-form') as HTMLFormElement;
  const template = document.getElementById('skill-item-template') as HTMLTemplateElement;

  const lists = {
    frontend: document.getElementById('list-frontend'),
    backend: document.getElementById('list-backend'),
    infra: document.getElementById('list-infra')
  };

  let currentSkills = [];

  async function fetchSkills() {
    if (loadingEl) loadingEl.classList.remove('hidden');
    if (container) container.classList.add('hidden');
    if (emptyEl) emptyEl.classList.add('hidden');

    try {
      const q = query(collection(db, 'skills'), orderBy('order', 'asc'));
      const snapshot = await getDocs(q);
      currentSkills = snapshot.docs.map(d => ({ id: d.id, ...d.data() }));
      
      renderSkills();
    } catch (error) {
      console.error("Fetch failed", error);
    } finally {
      if (loadingEl) loadingEl.classList.add('hidden');
    }
  }

  function renderSkills() {
    if (!container) return;
    
    // Clear all lists
    Object.values(lists).forEach(l => { if (l) l.innerHTML = ''; });

    if (currentSkills.length === 0) {
      if (emptyEl) emptyEl.classList.remove('hidden');
      return;
    }

    currentSkills.forEach(skill => {
      const list = lists[skill.category];
      if (!list) return;

      const clone = template.content.cloneNode(true) as HTMLElement;
      clone.querySelector('.skill-name')!.textContent = skill.name;
      
      const indicator = clone.querySelector('.level-indicator') as HTMLElement;
      if (skill.level === 'primary') {
        indicator.classList.add('bg-binary-green');
      } else {
        indicator.classList.add('bg-text-dim');
      }
      
      clone.querySelector('.s-edit-btn')!.addEventListener('click', () => openModal(skill));
      clone.querySelector('.s-delete-btn')!.addEventListener('click', () => deleteSkill(skill.id));
      
      list.appendChild(clone);
    });

    container.classList.remove('hidden');
  }

  function openModal(skill = null) {
    const titleEl = document.getElementById('s-modal-title');
    const idInput = document.getElementById('skill-id') as HTMLInputElement;
    
    if (skill) {
      if (titleEl) titleEl.textContent = 'Modify Skill Module';
      idInput.value = skill.id;
      (document.getElementById('s-name') as HTMLInputElement).value = skill.name;
      (document.getElementById('s-category') as HTMLSelectElement).value = skill.category;
      (document.getElementById('s-level') as HTMLSelectElement).value = skill.level;
      (document.getElementById('s-order') as HTMLInputElement).value = skill.order;
    } else {
      if (titleEl) titleEl.textContent = 'Register Skill Module';
      form.reset();
      idInput.value = '';
    }
    
    modal?.classList.remove('hidden');
  }

  async function deleteSkill(id) {
    if (confirm('Are you sure you want to DECOMMISSION this skill module?')) {
      await deleteDoc(doc(db, 'skills', id));
      fetchSkills();
    }
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const id = (document.getElementById('skill-id') as HTMLInputElement).value;
    
    const data = {
      name: (document.getElementById('s-name') as HTMLInputElement).value,
      category: (document.getElementById('s-category') as HTMLSelectElement).value,
      level: (document.getElementById('s-level') as HTMLSelectElement).value,
      order: parseInt((document.getElementById('s-order') as HTMLInputElement).value)
    };

    try {
      if (id) {
        await updateDoc(doc(db, 'skills', id), data);
      } else {
        await addDoc(collection(db, 'skills'), data);
      }
      modal?.classList.add('hidden');
      fetchSkills();
    } catch (error) {
      alert('Error syncing module. Check console.');
      console.error(error);
    }
  });

  document.getElementById('add-skill-btn')?.addEventListener('click', () => openModal());
  document.getElementById('close-skill-modal')?.addEventListener('click', () => modal?.classList.add('hidden'));
  document.getElementById('cancel-skill-modal')?.addEventListener('click', () => modal?.classList.add('hidden'));

  document.getElementById('seed-skills-btn')?.addEventListener('click', async () => {
    if (!confirm('This will seed the database with your original hardcoded skills. Continue?')) return;
    
    const initialSkills = [
      // Frontend
      { name: 'ReactTS', category: 'frontend', level: 'primary', order: 1 },
      { name: 'NextJS', category: 'frontend', level: 'primary', order: 2 },
      { name: 'VueJS', category: 'frontend', level: 'familiar', order: 3 },
      { name: 'Astro', category: 'frontend', level: 'familiar', order: 4 },
      { name: 'HTML/CSS', category: 'frontend', level: 'primary', order: 5 },
      { name: 'JavaScript', category: 'frontend', level: 'primary', order: 6 },
      // Backend
      { name: 'Python', category: 'backend', level: 'primary', order: 7 },
      { name: 'Java', category: 'backend', level: 'primary', order: 8 },
      { name: 'C++', category: 'backend', level: 'familiar', order: 9 },
      { name: 'JavaFX', category: 'backend', level: 'familiar', order: 10 },
      { name: 'Tkinter/CustomTkinter', category: 'backend', level: 'familiar', order: 11 },
      // Infra
      { name: 'Supabase', category: 'infra', level: 'primary', order: 12 },
      { name: 'MariaDB', category: 'infra', level: 'familiar', order: 13 },
      { name: 'MySQL', category: 'infra', level: 'primary', order: 14 },
      { name: 'PostgreSQL', category: 'infra', level: 'primary', order: 15 },
      { name: 'Debian/Ubuntu Server', category: 'infra', level: 'familiar', order: 16 },
      { name: 'Nginx', category: 'infra', level: 'familiar', order: 17 },
      { name: 'Cloudflare', category: 'infra', level: 'familiar', order: 18 },
      { name: 'Tailscale', category: 'infra', level: 'familiar', order: 19 },
    ];

    try {
      const skillsCol = collection(db, 'skills');
      for (const skill of initialSkills) {
        await addDoc(skillsCol, skill);
      }
      alert('Migration complete. System synchronized.');
      fetchSkills();
    } catch (error) {
      console.error('Migration failed', error);
      alert('Migration failed. Check console.');
    }
  });

  // Initialize
  fetchSkills();
</script>
