---
---

<div id="project-manager" class="space-y-10 animate-boot">
  <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6 border-l-2 border-binary-green pl-6 py-2">
    <div class="space-y-2">
      <h3 class="text-text-primary text-2xl font-black uppercase tracking-tighter flex items-center gap-3">
        <span class="text-binary-green">#</span> Project Database
      </h3>
      <p class="text-text-dim text-[10px] uppercase tracking-[0.3em] font-bold">Synchronizing repository records</p>
    </div>
    <button 
      id="add-project-btn"
      class="group py-3 px-6 bg-binary-green text-obsidian hover:brightness-110 transition-all text-[10px] uppercase tracking-[0.2em] font-black flex items-center gap-3"
    >
      <span class="text-lg leading-none">+</span> Create New Entry
    </button>
  </div>

  <!-- Loading State -->
  <div id="projects-loading" class="border border-system-border bg-layer-1 p-16 text-center space-y-6">
    <div class="relative inline-block w-12 h-12">
      <div class="absolute inset-0 border-2 border-binary-green/20 rounded-full"></div>
      <div class="absolute inset-0 border-2 border-binary-green border-t-transparent animate-spin rounded-full"></div>
    </div>
    <p class="text-text-dim text-[10px] uppercase tracking-[0.4em] animate-pulse font-bold">Querying_Firestore_Clusters...</p>
  </div>

  <!-- Empty State -->
  <div id="projects-empty" class="hidden border border-system-border bg-layer-1 p-20 text-center space-y-4">
    <div class="text-text-dim/20 text-5xl font-black">NULL</div>
    <p class="text-text-dim text-xs uppercase tracking-widest">No records found. Database is currently empty.</p>
  </div>

  <!-- Project List -->
  <div id="projects-list" class="hidden grid grid-cols-1 gap-4">
    <!-- Template content will be injected here -->
  </div>
</div>

<!-- Add/Edit Modal (System Overlay) -->
<div id="project-modal" class="hidden fixed inset-0 z-[200] overflow-y-auto">
  <!-- Backdrop -->
  <div class="fixed inset-0 bg-black/80 backdrop-blur-md"></div>
  
  <!-- Modal Content Wrapper -->
  <div class="relative min-h-screen flex items-center justify-center p-4 md:p-12">
    <div class="max-w-3xl w-full border border-system-border bg-layer-1 font-mono text-sm shadow-[0_0_100px_rgba(0,0,0,0.9)] animate-boot my-auto">
      <div class="bg-layer-2 border-b border-system-border p-4 flex justify-between items-center">
        <div class="flex items-center gap-3">
          <div class="w-1.5 h-1.5 bg-binary-green animate-pulse"></div>
          <span id="modal-title" class="text-text-primary uppercase tracking-[0.2em] font-black text-xs">New Record Entry</span>
        </div>
        <button id="close-modal" class="text-text-dim hover:text-white transition-colors p-1">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
        </button>
      </div>
      
      <form id="project-form" class="p-8 grid grid-cols-1 md:grid-cols-2 gap-8">
      <input type="hidden" id="project-id" />

        <div class="space-y-2">
          <label class="text-text-dim block text-[10px] uppercase tracking-widest font-bold">Project Title</label>
          <input type="text" id="p-title" required class="w-full bg-layer-2 border border-system-border p-3 outline-none focus:border-binary-green/50 text-text-primary transition-all text-xs" />
        </div>

        <div class="space-y-2">
          <label class="text-text-dim block text-[10px] uppercase tracking-widest font-bold">Timeline</label>
          <input type="text" id="p-date" required placeholder="Jan 2025 - Present" class="w-full bg-layer-2 border border-system-border p-3 outline-none focus:border-binary-green/50 text-text-primary transition-all text-xs" />
        </div>

        <div class="space-y-2 md:col-span-2">
          <label class="text-text-dim block text-[10px] uppercase tracking-widest font-bold">System Description</label>
          <textarea id="p-desc" required rows="4" class="w-full bg-layer-2 border border-system-border p-3 outline-none focus:border-binary-green/50 text-text-primary transition-all text-xs resize-none"></textarea>
        </div>

        <div class="space-y-2">
          <label class="text-text-dim block text-[10px] uppercase tracking-widest font-bold">Tech Stack (Comma Separated)</label>
          <input type="text" id="p-tags" required placeholder="Astro, Tailwind, Firebase" class="w-full bg-layer-2 border border-system-border p-3 outline-none focus:border-binary-green/50 text-text-primary transition-all text-xs" />
        </div>

        <div class="space-y-2">
          <label class="text-text-dim block text-[10px] uppercase tracking-widest font-bold">Sequence Order</label>
          <input type="number" id="p-order" required value="0" class="w-full bg-layer-2 border border-system-border p-3 outline-none focus:border-binary-green/50 text-text-primary transition-all text-xs" />
        </div>

        <div class="space-y-2">
          <label class="text-text-dim block text-[10px] uppercase tracking-widest font-bold">Repository Link</label>
          <input type="url" id="p-repo" required placeholder="https://github.com/..." class="w-full bg-layer-2 border border-system-border p-3 outline-none focus:border-binary-green/50 text-text-primary transition-all text-xs" />
        </div>

        <div class="space-y-2">
          <label class="text-text-dim block text-[10px] uppercase tracking-widest font-bold">Deployment Link (Optional)</label>
          <input type="url" id="p-live" placeholder="https://..." class="w-full bg-layer-2 border border-system-border p-3 outline-none focus:border-binary-green/50 text-text-primary transition-all text-xs" />
        </div>

        <div class="flex items-center gap-3 pt-2">
          <input type="checkbox" id="p-has-live" class="w-4 h-4 rounded-none border-system-border bg-layer-2 text-binary-green focus:ring-0" />
          <label for="p-has-live" class="text-text-dim text-[10px] uppercase tracking-widest font-bold cursor-pointer">Expose Live Link</label>
        </div>

        <div class="md:col-span-2 pt-6 flex flex-col sm:flex-row gap-4">
          <button type="submit" class="flex-grow py-4 bg-binary-green text-obsidian uppercase tracking-[0.2em] text-[10px] font-black hover:brightness-110 transition-all">Commit Changes to Cluster</button>
          <button type="button" id="cancel-modal" class="py-4 px-8 border border-system-border text-text-dim uppercase tracking-[0.2em] text-[10px] font-black hover:bg-layer-2 transition-all">Abort Transaction</button>
        </div>
      </form>
    </div>
  </div>
</div>
<template id="project-card-template">
  <div class="project-item border border-system-border bg-layer-1 p-6 flex justify-between items-center group hover:border-binary-green/50 transition-all duration-300">
    <div class="space-y-2">
      <div class="flex items-center gap-3">
        <div class="w-1 h-4 bg-system-border group-hover:bg-binary-green transition-colors"></div>
        <h4 class="project-title text-text-primary font-bold text-lg tracking-tight"></h4>
      </div>
      <div class="flex flex-wrap gap-x-4 gap-y-1 text-[10px] text-text-dim uppercase tracking-widest font-bold pl-4">
        <span class="project-date text-caution-yellow"></span>
        <span class="text-system-border-dim">|</span>
        <span class="project-tags text-text-muted"></span>
      </div>
    </div>
    <div class="flex gap-3">
      <button class="edit-btn p-3 border border-system-border text-text-dim hover:text-binary-green hover:border-binary-green/50 transition-all bg-layer-2" title="Edit Entry">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
        </svg>
      </button>
      <button class="delete-btn p-3 border border-system-border text-text-dim hover:text-red-500 hover:border-red-500/50 transition-all bg-layer-2" title="Purge Record">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
        </svg>
      </button>
    </div>
  </div>
</template>

<script>
  import { db } from '../../lib/firebase/client';
  import { collection, getDocs, query, orderBy, addDoc, updateDoc, deleteDoc, doc } from 'firebase/firestore';

  const projectsList = document.getElementById('projects-list');
  const loadingEl = document.getElementById('projects-loading');
  const emptyEl = document.getElementById('projects-empty');
  const modal = document.getElementById('project-modal');
  const projectForm = document.getElementById('project-form') as HTMLFormElement;
  const cardTemplate = document.getElementById('project-card-template') as HTMLTemplateElement;

  let currentProjects = [];

  async function fetchProjects() {
    if (loadingEl) loadingEl.classList.remove('hidden');
    if (projectsList) projectsList.classList.add('hidden');
    if (emptyEl) emptyEl.classList.add('hidden');

    try {
      const q = query(collection(db, 'projects'), orderBy('order', 'asc'));
      const snapshot = await getDocs(q);
      currentProjects = snapshot.docs.map(d => ({ id: d.id, ...d.data() }));
      
      renderProjects();
    } catch (error) {
      console.error("Fetch failed", error);
    } finally {
      if (loadingEl) loadingEl.classList.add('hidden');
    }
  }

  function renderProjects() {
    if (projectsList) {
      projectsList.innerHTML = '';
      if (currentProjects.length === 0) {
        if (emptyEl) emptyEl.classList.remove('hidden');
        return;
      }

      currentProjects.forEach(project => {
        const clone = cardTemplate.content.cloneNode(true) as HTMLElement;
        clone.querySelector('.project-title')!.textContent = project.title;
        clone.querySelector('.project-date')!.textContent = project.date;
        clone.querySelector('.project-tags')!.textContent = (project.tags || []).join(', ');
        
        clone.querySelector('.edit-btn')!.addEventListener('click', () => openModal(project));
        clone.querySelector('.delete-btn')!.addEventListener('click', () => deleteProject(project.id));
        
        projectsList.appendChild(clone);
      });
      projectsList.classList.remove('hidden');
    }
  }

  function openModal(project = null) {
    const titleEl = document.getElementById('modal-title');
    const idInput = document.getElementById('project-id') as HTMLInputElement;
    
    if (project) {
      if (titleEl) titleEl.textContent = 'Edit System Record';
      idInput.value = project.id;
      (document.getElementById('p-title') as HTMLInputElement).value = project.title;
      (document.getElementById('p-date') as HTMLInputElement).value = project.date;
      (document.getElementById('p-desc') as HTMLTextAreaElement).value = project.description;
      (document.getElementById('p-tags') as HTMLInputElement).value = (project.tags || []).join(', ');
      (document.getElementById('p-order') as HTMLInputElement).value = project.order;
      (document.getElementById('p-repo') as HTMLInputElement).value = project.repoUrl;
      (document.getElementById('p-live') as HTMLInputElement).value = project.liveUrl || '';
      (document.getElementById('p-has-live') as HTMLInputElement).checked = !!project.hasLiveUrl;
    } else {
      if (titleEl) titleEl.textContent = 'New Record Entry';
      projectForm.reset();
      idInput.value = '';
    }
    
    modal?.classList.remove('hidden');
  }

  async function deleteProject(id) {
    if (confirm('Are you sure you want to PURGE this record?')) {
      await deleteDoc(doc(db, 'projects', id));
      fetchProjects();
    }
  }

  projectForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const id = (document.getElementById('project-id') as HTMLInputElement).value;
    
    const data = {
      title: (document.getElementById('p-title') as HTMLInputElement).value,
      date: (document.getElementById('p-date') as HTMLInputElement).value,
      description: (document.getElementById('p-desc') as HTMLTextAreaElement).value,
      tags: (document.getElementById('p-tags') as HTMLInputElement).value.split(',').map(t => t.trim()),
      order: parseInt((document.getElementById('p-order') as HTMLInputElement).value),
      repoUrl: (document.getElementById('p-repo') as HTMLInputElement).value,
      liveUrl: (document.getElementById('p-live') as HTMLInputElement).value,
      hasLiveUrl: (document.getElementById('p-has-live') as HTMLInputElement).checked,
      staggerClass: `stagger-${currentProjects.length + 1}` // Simple logic for stagger
    };

    try {
      if (id) {
        await updateDoc(doc(db, 'projects', id), data);
      } else {
        await addDoc(collection(db, 'projects'), data);
      }
      modal?.classList.add('hidden');
      fetchProjects();
    } catch (error) {
      alert('Error committing changes. Check console.');
      console.error(error);
    }
  });

  document.getElementById('add-project-btn')?.addEventListener('click', () => openModal());
  document.getElementById('close-modal')?.addEventListener('click', () => modal?.classList.add('hidden'));
  document.getElementById('cancel-modal')?.addEventListener('click', () => modal?.classList.add('hidden'));

  // Initialize
  fetchProjects();
</script>
