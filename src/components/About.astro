---
const startYear = 2023;
const now = new Date();
const currentYear = now.getFullYear();
// If we're before August, we're still in the second half of the previous academic year
const academicYear = now.getMonth() < 7 ? currentYear - startYear : currentYear - startYear + 1;

const yearSuffix = (y: number) => {
  if (y === 1) return '1st';
  if (y === 2) return '2nd';
  if (y === 3) return '3rd';
  return `${y}th`;
};

const currentYearDisplay = yearSuffix(academicYear);
const educationPeriod = `2023 - Present (${currentYearDisplay} Year)`;
const deansListRange = `1st Year - Present (${currentYearDisplay} Year)`;
---

<section id="about" class="min-h-[calc(100vh-4rem-30px)] scroll-mt-14 flex flex-col justify-center border-b border-system-border bg-obsidian">
  <div class="p-5 md:p-8 py-12 md:py-16 flex-grow flex flex-col justify-center items-center">
    <div class="max-w-4xl w-full animate-on-scroll">
      <div class="flex gap-2 text-binary-green mb-6 md:mb-8 text-sm sm:text-base">
        <span class="font-bold" aria-hidden="true">❯</span>
        <span class="text-text-muted break-all">cat ./education_and_background.txt</span>
      </div>

      <h2 class="sr-only">About Me — Education & Background</h2>

      <div class="pl-3 sm:pl-4 border-l-2 border-system-border space-y-6 sm:space-y-8 text-text-muted leading-relaxed text-sm sm:text-base">
        <div class="animate-on-scroll stagger-1">
          <h3 class="text-caution-yellow font-bold mb-2 uppercase text-xs sm:text-sm tracking-widest">// Tertiary Education</h3>
          <p class="text-text-muted font-bold">University of Science and Technology of Southern Philippines</p>
          <p class="text-text-dim text-xs sm:text-sm">Bachelor of Science in Computer Science ({educationPeriod}) | Cagayan de Oro City</p>
          <ul class="list-disc list-inside text-text-dim mt-2 space-y-1">
            <li>Consistent Dean's List ({deansListRange}) with GPA Averages of 1.4 - 1.7</li>
            <li>Relevant Coursework: Parallel and Distributed Computing, Algorithms & Complexities, Machine Learning, Operating Systems</li>
          </ul>
        </div>

        <div class="animate-on-scroll stagger-2">
          <h3 class="text-caution-yellow font-bold mb-2 uppercase text-xs sm:text-sm tracking-widest">// Work Experience</h3>

          <div class="space-y-4">
            <div>
              <p class="text-text-muted font-bold">Full-Stack Developer <span class="text-text-dim/60 font-normal">@ JRJC Car Rental</span></p>
              <p class="text-text-dim text-xs sm:text-sm">Remote · Sep 2025</p>
              <ul class="list-disc list-inside text-text-dim mt-1 space-y-1">
                <li>Developed the booking system's management panel and Live Dashboard</li>
                <li>Built the Car Management module and Website's Content Management System</li>
                <li>Tech stack: Next.js, Supabase, Vercel</li>
              </ul>
            </div>

            <div>
              <p class="text-text-muted font-bold">Frontend Developer & QA <span class="text-text-dim/60 font-normal">@ Happsay</span></p>
              <p class="text-text-dim text-xs sm:text-sm">Remote · Jan 2025</p>
              <ul class="list-disc list-inside text-text-dim mt-1 space-y-1">
                <li>Assessed quality and fixed last-minute UI/UX bugs through rigorous QA testing</li>
                <li>Tech stack: React, Django REST Framework</li>
              </ul>
            </div>
          </div>
        </div>

        <div class="animate-on-scroll stagger-3">
          <h3 class="text-caution-yellow font-bold mb-2 uppercase text-xs sm:text-sm tracking-widest">// Career Objective</h3>
          <p class="text-text-dim">
            I am a full-time Computer Science student with practical experience working remotely as a full-stack developer. 
            I enjoy bridging logic and performance across complex systems, scaling from relational database architectures down to rich frontend frameworks.
          </p>
        </div>

      </div>

    </div>
  </div>
</section>