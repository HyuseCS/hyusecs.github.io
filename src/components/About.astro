---
import { db } from '../lib/firebase/client';
import { doc, getDoc, collection, getDocs, query, orderBy } from 'firebase/firestore';

const startYear = 2023;
const now = new Date();
const currentYear = now.getFullYear();
// If we're before August, we're still in the second half of the previous academic year
const academicYear = now.getMonth() < 7 ? currentYear - startYear : currentYear - startYear + 1;

const yearSuffix = (y: number) => {
  if (y === 1) return '1st';
  if (y === 2) return '2nd';
  if (y === 3) return '3rd';
  return `${y}th`;
};

const currentYearDisplay = yearSuffix(academicYear);

let ongoingProject = {
  title: 'Portfolio_System_Refactor',
  status: 'STABLE_BUILD',
  desc: 'Implementing "The System Monitor" design language and automated telemetry.'
};

let experiences = [];
let educations = [];

try {
  if (import.meta.env.PUBLIC_FIREBASE_API_KEY) {
    // 1. Fetch Ongoing Project
    const configRef = doc(db, 'system', 'config');
    const configSnap = await getDoc(configRef);
    if (configSnap.exists()) {
      const data = configSnap.data();
      if (data.ongoingProjectTitle) {
        ongoingProject = {
          title: data.ongoingProjectTitle,
          status: data.ongoingProjectStatus || 'ACTIVE',
          desc: data.ongoingProjectDesc || ''
        };
      }
    }

    // 2. Fetch Content and filter/sort in-memory to avoid composite index requirements
    const contentCol = collection(db, 'projects');
    const contentSnap = await getDocs(contentCol);
    
    if (!contentSnap.empty) {
      const allContent = contentSnap.docs.map(d => d.data());
      
      // Filter & Sort Experience
      experiences = allContent
        .filter(item => item.type === 'experience')
        .sort((a, b) => (b.startDate || '').localeCompare(a.startDate || ''));

      // Filter & Sort Education
      educations = allContent
        .filter(item => item.type === 'education')
        .sort((a, b) => (b.startDate || '').localeCompare(a.startDate || ''));
    }
  }
} catch (e) {
  console.error("Failed to fetch dynamic content", e);
}
---

<section id="about" class="min-h-[calc(100vh-4rem-30px)] flex flex-col justify-center border-b border-system-border bg-obsidian">
  <div class="p-5 md:p-8 py-12 md:py-16 flex-grow flex flex-col justify-center items-center">
    <div class="max-w-6xl w-full">
      <div class="flex gap-2 text-binary-green mb-8 text-sm sm:text-base animate-on-scroll">
        <span class="font-bold" aria-hidden="true">❯</span>
        <span class="text-text-muted break-all">cd ~/bio && ./about.sh</span>
      </div>

      <h2 class="sr-only">About Me — Education & Background</h2>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
        <!-- Left Side: Experience (Larger Space) -->
        <div class="lg:col-span-7 flex flex-col border border-system-border bg-layer-1 animate-on-scroll stagger-1 h-fit">
          <div class="flex items-center justify-between px-3 py-1.5 border-b border-system-border bg-system-border/10">
            <div class="flex items-center gap-2">
              <span class="w-2 h-2 bg-caution-yellow"></span>
              <span class="text-[10px] font-bold uppercase tracking-widest text-text-muted">experience.log</span>
            </div>
            <span class="text-[9px] text-text-dim font-mono">{experiences.length} ENTRIES FOUND</span>
          </div>
          <div class="p-4 space-y-6 overflow-y-auto custom-scrollbar max-h-[440px]">
            {experiences.length > 0 ? experiences.map((exp) => (
              <div class="grid grid-cols-1 sm:grid-cols-[100px_1fr] gap-2 sm:gap-6 group">
                <div class="text-[10px] font-mono text-text-dim mt-1 uppercase tracking-tighter">{exp.dateDisplay}</div>
                <div>
                  <h4 class="text-text-muted font-bold text-sm group-hover:text-binary-green transition-colors">{exp.title}</h4>
                  <p class="text-text-dim text-[10px] uppercase font-bold tracking-widest mb-3">{exp.subtitle}</p>
                  <ul class="space-y-2 text-xs text-text-dim/80">
                    {(exp.description || '').split('\n').map((bullet) => (
                      <li class="flex gap-2">
                        <span class="text-binary-green font-bold">›</span>
                        <span>{bullet.replace(/^•\s*/, '')}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            )) : (
              <div class="text-text-dim text-xs font-mono py-10 text-center uppercase tracking-widest">
                [ No Experience Records Found ]
              </div>
            )}
          </div>
        </div>

        <!-- Right Side: Ongoing Project & Education -->
        <div class="lg:col-span-5 flex flex-col gap-6">
          <!-- Pane: Ongoing Project (Scrollable) -->
          <div class="flex flex-col border border-system-border bg-layer-1 animate-on-scroll stagger-2 max-h-[180px]">
            <div class="flex items-center justify-between px-3 py-1.5 border-b border-system-border bg-system-border/10">
              <div class="flex items-center gap-2">
                <span class="w-2 h-2 bg-binary-green"></span>
                <span class="text-[10px] font-bold uppercase tracking-widest text-text-muted">current_process.d</span>
              </div>
              <span class="text-[9px] text-binary-green font-mono">[ ACTIVE ]</span>
            </div>
            <div class="p-4 overflow-y-auto custom-scrollbar space-y-3">
              <div>
                <h3 class="text-caution-yellow font-bold uppercase text-xs tracking-widest mb-1">// Ongoing Project</h3>
                <p class="text-text-primary font-mono text-sm leading-tight">{ongoingProject.title}</p>
              </div>
              <div class="space-y-2">
                <div class="flex items-center justify-between text-[10px] font-mono text-text-dim">
                  <span>STATUS</span>
                  <span class="text-binary-green">{ongoingProject.status}</span>
                </div>
                <div class="h-1 w-full bg-layer-2 border border-system-border overflow-hidden">
                  <div class="h-full bg-binary-green w-3/4 animate-pulse"></div>
                </div>
              </div>
              <p class="text-text-dim text-xs leading-relaxed font-mono whitespace-pre-wrap">
                {ongoingProject.desc}
              </p>
            </div>
          </div>

          <!-- Pane: Education -->
          <div class="border border-system-border bg-layer-1 animate-on-scroll stagger-3 h-fit">
            <div class="flex items-center justify-between px-3 py-1.5 border-b border-system-border bg-system-border/10">
              <div class="flex items-center gap-2">
                <span class="w-2 h-2 bg-text-dim"></span>
                <span class="text-[10px] font-bold uppercase tracking-widest text-text-muted">education.log</span>
              </div>
              <span class="text-[9px] text-text-dim font-mono">{educations.length} ENTRIES</span>
            </div>
            <div class="p-4 space-y-6 overflow-y-auto custom-scrollbar max-h-[236px]">
              {educations.length > 0 ? educations.map((edu) => (
                <div class="grid grid-cols-1 gap-4">
                  <div class="flex items-center justify-between">
                    <div class="text-[10px] font-mono text-text-dim uppercase tracking-tighter">{edu.dateDisplay}</div>
                    {edu.rank && (
                      <div class="text-[9px] text-caution-yellow font-bold uppercase tracking-widest px-2 py-0.5 border border-caution-yellow/30 bg-caution-yellow/5">
                        {edu.rank}
                      </div>
                    )}
                  </div>
                  <div class="space-y-3">
                    <div>
                      <h4 class="text-text-muted font-bold text-sm">{edu.title}</h4>
                      <p class="text-text-dim text-[10px] uppercase font-bold tracking-widest">{edu.subtitle}</p>
                    </div>
                    {edu.status && (
                      <div class="border border-system-border p-2 bg-layer-2/50 flex justify-between items-center text-xs font-mono">
                        <span class="text-[9px] text-text-dim uppercase">Current_Level</span>
                        <span class="text-binary-green">{edu.status}</span>
                      </div>
                    )}
                    <div class="text-[10px] text-text-dim/80 leading-relaxed bg-obsidian/30 p-2 border-l border-system-border">
                      <span class="text-binary-green font-bold mr-2">QUERY:</span>
                      {edu.description}
                    </div>
                  </div>
                </div>
              )) : (
                <div class="text-text-dim text-xs font-mono py-4 text-center">
                  [ No Education Records ]
                </div>
              )}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .custom-scrollbar::-webkit-scrollbar {
    width: 4px;
  }
  .custom-scrollbar::-webkit-scrollbar-track {
    background: transparent;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb {
    background: #333333;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb:hover {
    background: #444444;
  }
</style>
