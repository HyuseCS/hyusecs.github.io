  <div class="p-5 md:p-8 py-12 md:py-16 flex-grow flex flex-col items-center justify-center">
    <div class="max-w-5xl w-full animate-on-scroll">
      
      <h2 class="sr-only">Contact Information</h2>
      
      <div class="flex flex-col lg:flex-row gap-6 lg:gap-8">
        
        <!-- Left: Contact Info -->
