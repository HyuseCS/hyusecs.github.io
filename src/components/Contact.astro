          <div class="flex gap-2 text-binary-green mb-4 text-sm sm:text-base">
            <span class="font-bold" aria-hidden="true">❯</span>
            <span class="text-text-muted">ping -c 4 hyuse.dev</span>
          </div>
          
          <div class="p-5 sm:p-8 border border-system-border bg-layer-1 flex-grow flex flex-col">
            <p class="text-text-dim text-xs sm:text-sm mb-4 sm:mb-6 font-mono border-b border-system-border pb-4">
              // Connection established. Ready to receive transmissions.
            </p>
            
            <dl class="space-y-4 sm:space-y-5 flex-grow">
              <div class="flex flex-col sm:flex-row sm:items-center gap-1 sm:gap-6">
                <dt class="text-caution-yellow w-24 font-bold uppercase text-xs tracking-widest shrink-0">Email:</dt>
                <dd>
                  <a href="mailto:christianjohn.legaspi@1.ustp.edu.ph" class="text-white hover:text-binary-green hover:underline decoration-dashed transition-colors text-xs sm:text-sm break-all">
                    christianjohn.legaspi@1.ustp.edu.ph
                  </a>
                </dd>
              </div>
              
              <div class="flex flex-col sm:flex-row sm:items-center gap-1 sm:gap-6">
                <dt class="text-caution-yellow w-24 font-bold uppercase text-xs tracking-widest shrink-0">Phone:</dt>
                <dd class="text-white text-sm md:text-base font-mono">
                  (+63) 968 301 3514
                </dd>
              </div>

              <div class="flex flex-col sm:flex-row sm:items-center gap-1 sm:gap-6">
                <dt class="text-caution-yellow w-24 font-bold uppercase text-xs tracking-widest shrink-0">Github:</dt>
                <dd>
                  <a href="https://github.com/hyuseCS" target="_blank" class="text-white hover:text-binary-green hover:underline decoration-dashed transition-colors text-sm md:text-base break-all">
                    github.com/hyuseCS
                  </a>
                </dd>
              </div>
              
              <div class="flex flex-col sm:flex-row sm:items-center gap-1 sm:gap-6">
                <dt class="text-caution-yellow w-24 font-bold uppercase text-xs tracking-widest shrink-0">Resume:</dt>
                <dd class="relative group cursor-pointer mt-1 sm:mt-0">
                  <a href="/LEGASPI_RESUME.pdf" target="_blank" class="text-white hover:text-binary-green hover:underline decoration-dashed transition-colors text-sm md:text-base break-all inline-block">
                    View Resume
                  </a>
                  
                  <!-- PDF Hover Panel (Desktop Only) -->
                  <div class="absolute bottom-full left-0 md:left-0 lg:-left-32 mb-4 w-[320px] h-[400px] md:w-[600px] md:h-[800px] bg-layer-2 border border-system-border opacity-0 pointer-events-none group-hover:opacity-100 group-hover:pointer-events-auto transition-all duration-300 z-50 rounded-sm overflow-hidden hidden md:block origin-bottom-left scale-95 group-hover:scale-100">
                    <div class="bg-surface-high flex items-center justify-between px-3 py-1.5 border-b border-system-border">
                      <span class="text-text-dim font-mono text-[10px]">previewing: LEGASPI_RESUME.pdf</span>
                      <span class="text-caution-yellow font-mono text-[10px] flex items-center gap-2">
                        <span class="w-2 h-2 rounded-full bg-caution-yellow animate-pulse" aria-hidden="true"></span> Rendering
                      </span>
                    </div>
                    <iframe src="/LEGASPI_RESUME.pdf#toolbar=0&navpanes=0&scrollbar=0&view=FitH" loading="lazy" class="w-full h-[calc(100%-28px)] border-none bg-neutral-100" title="Resume preview"></iframe>
                  </div>
                </dd>
              </div>
              
              <div class="flex flex-col sm:flex-row sm:items-center gap-1 sm:gap-6 pt-4 border-t border-system-border-dim">
                <dt class="text-text-dim w-24 font-bold uppercase text-xs sm:text-sm tracking-widest shrink-0">Location:</dt>
                <dd class="text-binary-green text-sm md:text-base font-bold">
                  Cagayan de Oro, Philippines
                </dd>
              </div>
            </dl>
          </div>
        </div>

        <!-- Right: Contact Form -->
        <div class="w-full lg:w-1/2 flex flex-col animate-on-scroll stagger-2">
          <div class="flex gap-2 text-binary-green mb-4 text-sm sm:text-base">
            <span class="font-bold" aria-hidden="true">❯</span>
            <span class="text-text-muted">./send_message.sh</span>
          </div>
          
          <form id="contact-form" action="https://api.web3forms.com/submit" method="POST" class="p-5 sm:p-8 border border-system-border bg-layer-1 space-y-4 sm:space-y-5 flex-grow flex flex-col">
            <!-- Replace with your Web3Forms access key -->
            <input type="hidden" name="access_key" value="f2d56782-a1aa-49aa-86a1-106e7a4342a0">
            <input type="hidden" name="subject" value="New message from CJ Portfolio">
            <input type="hidden" name="from_name" value="Portfolio Contact Form">
            
            <p class="text-text-dim text-xs sm:text-sm font-mono border-b border-system-border pb-4">
              // Send a transmission directly. All fields required.
            </p>
            
            <div class="flex flex-col sm:flex-row gap-4">
              <div class="flex-1">
                <label for="contact-name" class="text-caution-yellow text-xs font-bold uppercase tracking-widest block mb-2">Name:</label>
                <input 
                  type="text" 
                  id="contact-name"
                  name="name" 
                  required 
                  class="form-input"
                  placeholder="John Doe"
                  autocomplete="name"
                />
              </div>
              <div class="flex-1">
                <label for="contact-email" class="text-caution-yellow text-xs font-bold uppercase tracking-widest block mb-2">Email:</label>
                <input 
                  type="email" 
                  id="contact-email"
                  name="email" 
                  required 
                  class="form-input"
                  placeholder="john@example.com"
                  autocomplete="email"
                />
              </div>
            </div>
            
            <div class="flex-grow flex flex-col">
              <label for="contact-message" class="text-caution-yellow text-xs font-bold uppercase tracking-widest block mb-2">Message:</label>
              <textarea 
                id="contact-message"
                name="message" 
                required 
                rows="4" 
                class="form-input resize-none flex-grow min-h-[120px]"
                placeholder="Write your message here..."
              ></textarea>
            </div>
            
            <div class="items-center justify-between pt-2">
              <div id="form-status" class="text-xs font-mono"></div>
              <button 
                type="submit" 
                class="px-6 py-2 border border-binary-green text-binary-green hover:bg-binary-green hover:text-black font-mono text-xs sm:text-sm transition-colors cursor-pointer"
              >
                [ Transmit ]
              </button>
            </div>
          </form>
        </div>

      </div>
      
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('contact-form');
    const status = document.getElementById('form-status');
    
    if (form && status) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const submitBtn = form.querySelector('button[type="submit"]');
        const originalText = submitBtn.textContent;
        submitBtn.textContent = '[ Transmitting... ]';
        submitBtn.disabled = true;
        status.textContent = '';
        
        try {
          const formData = new FormData(form);
          const response = await fetch('https://api.web3forms.com/submit', {
            method: 'POST',
            body: formData
          });
          
          const data = await response.json();
          
          if (data.success) {
            status.innerHTML = '<span class="text-binary-green">✓ Transmission sent successfully.</span>';
            form.reset();
          } else {
            status.innerHTML = '<span class="text-error">✕ Transmission failed. Try email instead.</span>';
          }
        } catch (error) {
          status.innerHTML = '<span class="text-error">✕ Network error. Try email instead.</span>';
        }
        
        submitBtn.textContent = originalText;
        submitBtn.disabled = false;
      });
    }
  });
</script>