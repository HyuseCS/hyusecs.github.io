---
import { getSystemConfig } from '../lib/firebase/config';

const config = await getSystemConfig();
const { resumeUrl, email, location, phone } = config;
---

<section id="contact" class="min-h-[calc(100vh-4rem-30px)] scroll-mt-14 flex flex-col justify-center border-b border-system-border bg-obsidian">
  <div class="p-5 md:p-8 py-12 md:py-16 flex-grow flex flex-col justify-center items-center">
    <div class="max-w-6xl w-full">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">
        
        <!-- Contact Info & Links -->
        <div class="space-y-8 animate-on-scroll">
          <div class="space-y-4">
            <div class="flex gap-2 text-binary-green mb-4 text-xs sm:text-sm">
              <span class="font-bold">❯</span>
              <span class="text-text-muted">systemctl status network.service</span>
            </div>
            <h2 class="text-text-primary text-3xl sm:text-4xl font-bold uppercase tracking-tighter leading-none">
              Initialize Connection
            </h2>
            <p class="text-text-muted text-base leading-relaxed max-w-md">
              Available for freelance opportunities and full-stack collaborations. 
              Drop a signal through the encrypted form or reach out via direct channels.
            </p>
          </div>

          <div class="space-y-6">
            <dl class="grid grid-cols-1 gap-4 border-l border-system-border pl-6">
              <div class="flex flex-col sm:flex-row sm:items-baseline gap-2">
                <dt class="text-caution-yellow w-24 font-bold uppercase text-xs tracking-widest shrink-0">Email:</dt>
                <dd>
                  <a href={`mailto:${email}`} class="text-white hover:text-binary-green transition-colors text-sm md:text-base break-all">
                    {email}
                  </a>
                </dd>
              </div>
              <div class="flex flex-col sm:flex-row sm:items-baseline gap-2">
                <dt class="text-caution-yellow w-24 font-bold uppercase text-xs tracking-widest shrink-0">Location:</dt>
                <dd class="text-text-muted text-sm md:text-base">{location}</dd>
              </div>
              <div class="flex flex-col sm:flex-row sm:items-baseline gap-2">
                <dt class="text-caution-yellow w-24 font-bold uppercase text-xs tracking-widest shrink-0">Contact:</dt>
                <dd class="text-text-muted text-sm md:text-base">{phone}</dd>
              </div>
              <div class="flex flex-col sm:flex-row sm:items-baseline gap-2">
                <dt class="text-caution-yellow w-24 font-bold uppercase text-xs tracking-widest shrink-0">Resume:</dt>
                <dd class="relative group">
                  <a href={resumeUrl} target="_blank" class="text-white hover:text-binary-green hover:underline decoration-dashed transition-colors text-sm md:text-base break-all inline-block">
                    View Resume
                  </a>

                  <!-- Floating Preview Card (Desktop Only) -->
                  <div class="absolute bottom-full left-0 w-64 md:w-80 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 group-hover:delay-0 delay-150 z-50 pointer-events-none group-hover:pointer-events-auto">
                    <!-- Invisible Bridge to allow mouse movement to tooltip -->
                    <div class="absolute top-full h-8 w-full"></div>
                    
                    <div class="border border-system-border bg-neutral-surface p-2 shadow-2xl space-y-2 font-mono mb-4">
                      <div class="p-2 border-b border-system-border bg-neutral-layer flex justify-between items-center">
                        <div class="flex gap-1">
                          <div class="w-1.5 h-1.5 rounded-full bg-system-border"></div>
                          <div class="w-1.5 h-1.5 rounded-full bg-system-border"></div>
                        </div>
                        <span class="text-text-dim font-mono text-[9px]">previewing: {resumeUrl.split('/').pop()}</span>
                      </div>
                      <div class="bg-neutral-layer border border-system-border aspect-[3/4] relative overflow-hidden">
                        <iframe src={`${resumeUrl}#toolbar=0&navpanes=0&scrollbar=0&view=FitH`} class="w-full h-full border-none bg-neutral-100" title="Resume preview"></iframe>
                      </div>
                    </div>
                  </div>
                </dd>
              </div>
            </dl>
          </div>
        </div>

        <!-- Contact Form (The Terminal) -->
        <div class="animate-on-scroll stagger-1">
          <div class="border border-system-border bg-neutral-surface shadow-2xl relative overflow-hidden group">
            <div class="bg-neutral-layer border-b border-system-border p-3 flex justify-between items-center">
              <div class="flex gap-1.5">
                <div class="w-2.5 h-2.5 rounded-full bg-red-500/20 border border-red-500/40"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-yellow-500/20 border border-yellow-500/40"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-binary-green/20 border border-binary-green/40"></div>
              </div>
              <span class="text-text-dim text-[10px] font-mono uppercase tracking-widest">encrypted_form.sh</span>
            </div>
            
            <form id="contact-form" class="p-6 md:p-8 space-y-6">
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="space-y-1">
                  <label for="name" class="text-text-dim block text-[10px] uppercase tracking-wider">Ident:</label>
                  <input 
                    type="text" 
                    id="name" 
                    name="name" 
                    required 
                    placeholder="User Name"
                    class="w-full bg-neutral-layer border border-system-border p-3 outline-none focus:border-binary-green text-text-primary transition-colors text-sm"
                  />
                </div>
                <div class="space-y-1">
                  <label for="email" class="text-text-dim block text-[10px] uppercase tracking-wider">Return Path:</label>
                  <input 
                    type="email" 
                    id="email" 
                    name="email" 
                    required 
                    placeholder="email@address.com"
                    class="w-full bg-neutral-layer border border-system-border p-3 outline-none focus:border-binary-green text-text-primary transition-colors text-sm"
                  />
                </div>
              </div>

              <div class="space-y-1">
                <label for="message" class="text-text-dim block text-[10px] uppercase tracking-wider">Payload:</label>
                <textarea 
                  id="message" 
                  name="message" 
                  required 
                  rows="4" 
                  placeholder="Enter transmission data..."
                  class="w-full bg-neutral-layer border border-system-border p-3 outline-none focus:border-binary-green text-text-primary transition-colors text-sm resize-none"
                ></textarea>
              </div>

              <button 
                type="submit" 
                class="w-full py-4 border-2 border-binary-green text-binary-green hover:bg-binary-green hover:text-obsidian transition-all uppercase tracking-widest font-bold flex items-center justify-center gap-3 group"
              >
                <span class="group-hover:translate-x-1 transition-transform">❯</span> Transmit Data
              </button>

              <div id="form-status" class="hidden text-center text-xs font-mono py-2">
                <!-- Status messages will appear here -->
              </div>
            </form>
            
            <!-- Terminal Decorative Overlay -->
            <div class="absolute bottom-2 right-4 text-text-dim/20 text-[60px] font-bold pointer-events-none select-none tracking-tighter italic">
              COMMS
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>

<script>
  // Simple form feedback logic
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const statusEl = document.getElementById('form-status');

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    if (!statusEl) return;

    statusEl.classList.remove('hidden', 'text-red-500', 'text-binary-green');
    statusEl.textContent = '[PENDING] ESTABLISHING_UPLINK...';
    
    // Simulate API call
    setTimeout(() => {
      statusEl.classList.add('text-binary-green');
      statusEl.textContent = '[SUCCESS] TRANSMISSION_RECEIVED';
      form.reset();
      
      setTimeout(() => {
        statusEl.classList.add('hidden');
      }, 5000);
    }, 1500);
  });
</script>
