---
let fallbackMatrixData = null;
try {
  // Primary: GitHub GraphQL API for accurate per-day contribution counts
  const token = import.meta.env.GH_TOKEN;
  if (token) {
    const currentYear = new Date().getFullYear();
    const years = [];
    const allContributions = [];

    const colorToIntensity = {
      '#ebedf0': '0',
      '#9be9a8': '1',
      '#40c463': '2',
      '#30a14e': '3',
      '#216e39': '4',
    };

    for (let year = currentYear; year >= currentYear - 2; year--) {
      const from = `${year}-01-01T00:00:00Z`;
      const to = `${year}-12-31T23:59:59Z`;

      const query = `
        query($login: String!, $from: DateTime!, $to: DateTime!) {
          user(login: $login) {
            contributionsCollection(from: $from, to: $to) {
              contributionCalendar {
                totalContributions
                weeks {
                  contributionDays {
                    contributionCount
                    date
                    color
                  }
                }
              }
            }
          }
        }
      `;

      const res = await fetch('https://api.github.com/graphql', {
        method: 'POST',
        headers: {
          'Authorization': `bearer ${token}`,
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({ query, variables: { login: 'hyuseCS', from, to } }),
      });

      if (res.ok) {
        const json = await res.json();
        if (json.data?.user?.contributionsCollection) {
          const calendar = json.data.user.contributionsCollection.contributionCalendar;
          if (calendar.totalContributions > 0 || year === currentYear) {
            years.push({ year: String(year), total: calendar.totalContributions });
          }
          calendar.weeks.forEach(week => {
            week.contributionDays.forEach(day => {
              allContributions.push({
                date: day.date,
                count: day.contributionCount,
                color: day.color,
                intensity: colorToIntensity[day.color] || (day.contributionCount > 0 ? '1' : '0'),
              });
            });
          });
        }
      }
    }

    if (years.length > 0) {
      fallbackMatrixData = { years, contributions: allContributions, source: 'graphql' };
    }
  }

  // Fallback: Third-party API if no token configured or GraphQL fails
  if (!fallbackMatrixData) {
    const staticRes = await fetch('https://github-contributions.vercel.app/api/v1/hyuseCS');
    if (staticRes.ok) {
      fallbackMatrixData = await staticRes.json();
      fallbackMatrixData.source = 'fallback-api';
    }
  }
} catch (e) {
  // Silent fallback
}
