<!-- Tracking Scripts -->
<script define:vars={{ fallbackMatrixData }}>
  document.addEventListener('DOMContentLoaded', async () => {
    // 1. Ticking Clock Daemon
    const timeEl = document.getElementById('local-time');
    if(timeEl) {
      timeEl.textContent = new Date().toLocaleTimeString('en-US', { timeZone: 'Asia/Manila', hour12: false });
      setInterval(() => {
        const now = new Date();
        timeEl.textContent = now.toLocaleTimeString('en-US', { timeZone: 'Asia/Manila', hour12: false });
      }, 1000);
    }

    // 2. Github Activity Telemetry (Live Events)
    const eventContainer = document.getElementById('github-activity');
    if(eventContainer) {
      try {
        const res = await fetch('https://api.github.com/users/hyuseCS/events/public?per_page=15');
        if(!res.ok) throw new Error('API Error');
        const events = await res.json();
        
        const pushes = events.filter(e => e.type === 'PushEvent').slice(0, 8);
        eventContainer.innerHTML = '';
        
        if(pushes.length === 0){
           eventContainer.innerHTML = '<div class="text-[#ffbd2e] flex flex-col p-4 border border-[#333] bg-[#1a1a1a] rounded-sm col-span-1 border-dashed">// No recent push events found.</div>';
        } else {
          pushes.forEach(push => {
            const repo = push.repo.name;
            const msg = (push.payload.commits && push.payload.commits.length > 0) 
                ? push.payload.commits[0].message.split('\\n')[0] 
                : 'Branch updated';
            const strTime = new Date(push.created_at).toLocaleDateString(undefined, {month:'short', day:'numeric'});
            
            const el = document.createElement('div');
            el.className = 'border border-[#333] bg-[#1a1a1a] p-4 flex flex-col justify-center hover:border-[#27c93f] transition-colors rounded-sm';
            el.innerHTML = `
              <div class="flex flex-wrap sm:flex-nowrap justify-between items-center w-full gap-2 sm:gap-0">
                <div class="text-[#d4d4d4] font-bold truncate pr-3 text-xs sm:text-sm">git push <a href="https://github.com/${repo}" target="_blank" class="text-[#27c93f] hover:underline">${repo.replace('hyuseCS/', '')}</a></div>
                <div class="text-[10px] text-[#555] shrink-0 whitespace-nowrap">${strTime}</div>
              </div>
              <div class="truncate opacity-75 text-xs text-[#888] w-full mt-1">"${msg}"</div>
            `;
            eventContainer.appendChild(el);
          });
        }
      } catch (err) {
        eventContainer.innerHTML = '<div class="text-[#e06c75] p-4 border border-[#333] bg-[#1a1a1a] rounded-sm flex items-center gap-2"><span class="text-[#e06c75]">✕</span> // Telemetry daemon offline (Rate limited Github REST API)</div>';
      }
    }

    // 3. Dynamic Contribution Matrix
    try {
      if (!fallbackMatrixData) {
        throw new Error('Fatal: SSR cache missing.');
      }
      
      const matrixData = fallbackMatrixData;
      
      const hasAccurateCounts = matrixData.source === 'graphql';
      
      const years = matrixData.years.map(y => y.year);
      const yearFilter = document.getElementById('year-filter');
      const container = document.getElementById('matrix-container');
      
      yearFilter.innerHTML = years.map(y => `<option value="${y}">${y}</option>`).join('');
      
      const renderMatrix = (targetYear) => {
        let days = matrixData.contributions.filter(c => c.date.startsWith(targetYear));
        if (days.length === 0) {
          container.innerHTML = '<div class="text-[#ffbd2e] text-xs font-mono">// No history logged for this year.</div>';
          return;
        }
        
        days.sort((a,b) => new Date(a.date) - new Date(b.date));
        
        let firstDay = new Date(days[0].date).getDay();
        let htmlWeeks = [];
        let curWeek = [];
        
        for(let i = 0; i < firstDay; i++) { curWeek.push(null); }
        
        days.forEach(day => {
          curWeek.push(day);
          if(curWeek.length === 7) {
            htmlWeeks.push(curWeek);
            curWeek = [];
          }
        });
        if(curWeek.length > 0) htmlWeeks.push(curWeek);
        
        const monthNames = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
        let monthLabelsHtml = '';
        let lastMonth = -1;
        
        htmlWeeks.forEach((week, index) => {
           const firstValidDay = week.find(d => d !== null);
           if(firstValidDay) {
              const month = new Date(firstValidDay.date).getMonth();
              if(month !== lastMonth) {
                 monthLabelsHtml += `<span class="absolute top-0 pointer-events-none" style="left: ${index * 17}px">${monthNames[month]}</span>`;
                 lastMonth = month;
              }
           }
        });
        
        const matrixBody = htmlWeeks.map((week, index) => {
          const edgeClass = index < 4 ? " edge-left" : (index >= htmlWeeks.length - 4 ? " edge-right" : "");
          return `
          <div class="matrix-col flex flex-col gap-1${edgeClass}">
            ${week.map((day, i) => {
               if(!day) return '<div class="w-[13px] h-[13px] bg-transparent rounded-[2px] pointer-events-none"></div>';
               const bg = day.intensity === "0" ? "#1a1a1a" :
                          day.intensity === "1" ? "#0e4429" :
                          day.intensity === "2" ? "#006d32" :
                          day.intensity === "3" ? "#26a641" : "#39d353";
               const countTxt = hasAccurateCounts
                 ? (day.count > 0 ? `${day.count} contribution${day.count !== 1 ? 's' : ''}` : 'No contributions')
                 : (day.intensity !== '0' ? 'Contributions' : 'No contributions');
               
               const isTopEdge = i < 2;
               const isBottomEdge = i > 4;
               const edgeYClass = isTopEdge ? ' edge-top' : (isBottomEdge ? ' edge-bottom' : '');
               
               return `
                 <div class="matrix-cell${edgeYClass} relative group inline-block focus:outline-none" tabindex="0" data-tooltip="${countTxt} on ${day.date}" aria-label="${countTxt} on ${day.date}">
                   <div class="w-[13px] h-[13px] rounded-[2px] border border-white/5 group-hover:border-[#27c93f] transform group-hover:scale-[1.35] transition-all cursor-crosshair" style="background-color: ${bg};"></div>
                 </div>
               `;
            }).join('')}
          </div>
        `;
        }).join('');
        
        container.innerHTML = `
          <div class="flex flex-col gap-1 min-w-max px-2">
            <div class="relative h-4 text-[9px] text-[#555] font-mono ml-7 w-full leading-none">
              ${monthLabelsHtml}
            </div>
            
            <div class="flex gap-2">
              <div class="relative w-6 h-[115px] text-[10px] text-[#555] font-mono text-right pointer-events-none" aria-hidden="true">
                 <span class="absolute right-0" style="top: 17px; line-height: 12px">Mon</span>
                 <span class="absolute right-0" style="top: 51px; line-height: 12px">Wed</span>
                 <span class="absolute right-0" style="top: 85px; line-height: 12px">Fri</span>
              </div>
              <div class="flex gap-1 select-none pointer-events-auto pb-2">
                ${matrixBody}
              </div>
            </div>
          </div>
        `;
      };
      
      renderMatrix(years[0]);
      
      yearFilter.addEventListener('change', (e) => {
        renderMatrix(e.target.value);
      });
      
    } catch (e) {
      document.getElementById('matrix-container').innerHTML = '<div class="text-[#e06c75] text-xs font-mono flex items-center gap-2"><span>✕</span> // Matrix datalink severed (Global Network Integrity Failure)</div>';
    }
  });
</script>
div>';
    }
  });
</script>
