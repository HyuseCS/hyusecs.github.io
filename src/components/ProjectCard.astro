---
export interface Props {
  title: string;
  date: string;
  description: string;
  tags: string[];
  repoUrl?: string;
  liveUrl?: string;
  hasLiveUrl?: boolean;
  thumbnail?: string;
  className?: string;
  staggerClass?: string;
}

const { 
  title, 
  date, 
  description, 
  tags, 
  repoUrl = "#", 
  liveUrl = "#", 
  hasLiveUrl = true,
  thumbnail = "",
  className = "",
  staggerClass = "stagger-1"
} = Astro.props;
---

<article class={`group relative flex flex-col justify-between border border-system-border bg-layer-1 hover:border-binary-green transition-all hover:-translate-y-1 animate-on-scroll ${staggerClass} overflow-hidden ${className}`}>
  
  <!-- Project Thumbnail -->
  {thumbnail && (
    <div class="w-full h-36 sm:h-44 overflow-hidden border-b border-system-border relative">
      <img 
        src={thumbnail} 
        alt={`Screenshot of ${title}`} 
        class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-500"
        loading="lazy"
      />
      <div class="absolute inset-0 bg-obsidian/40"></div>
    </div>
  )}

  <div class="p-5 sm:p-6 flex flex-col flex-grow">
    <div>
      <div class="flex justify-between items-start mb-4">
        <h3 class="text-lg sm:text-xl font-bold text-white group-hover:text-binary-green transition-colors">{title}</h3>
        <span class="text-text-dim text-xs shrink-0 ml-2 mt-1">{date}</span>
      </div>
      <p class="text-text-dim text-sm mb-6 leading-relaxed">
        {description}
      </p>
      <div class="flex flex-wrap gap-2 mb-6 md:mb-0">
        {tags.map(tag => (
          <span class="text-xs font-mono text-caution-yellow bg-surface-high px-2 py-1 rounded-sm relative z-10">{tag}</span>
        ))}
      </div>
    </div>

    <!-- Decorative Git Workflow Background Graphic -->
    <svg class="absolute -right-4 -bottom-4 w-40 h-40 text-system-border-dim group-hover:text-binary-green group-hover:-translate-x-4 group-hover:-translate-y-4 transition-all duration-700 opacity-30 group-hover:opacity-10 pointer-events-none stroke-current z-0" viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <line x1="6" y1="3" x2="6" y2="15"></line>
      <circle cx="18" cy="6" r="3"></circle>
      <circle cx="6" cy="18" r="3"></circle>
      <path d="M18 9a9 9 0 0 1-9 9"></path>
    </svg>

    <!-- Mobile Action Buttons (Visible statically on touch/small screens) -->
    <div class="mt-auto flex flex-col sm:flex-row gap-3 md:hidden pt-4">
      <a href={repoUrl} target="_blank" class="px-4 py-2 w-full text-center border border-text-muted text-text-muted hover:bg-text-muted hover:text-black font-mono text-xs sm:text-sm transition-colors" aria-label={`View source code for ${title}`}>
        [ Source Code ]
      </a>
      {hasLiveUrl && (
        <a href={liveUrl} target="_blank" class="px-4 py-2 w-full text-center border border-binary-green text-binary-green hover:bg-binary-green hover:text-black font-mono text-xs sm:text-sm transition-colors" aria-label={`View live site for ${title}`}>
          [ Live Site ]
        </a>
      )}
    </div>

    <!-- Desktop Hover Overlay Menu (Hidden on mobile) -->
    <div class="absolute inset-0 bg-obsidian/90 backdrop-blur-sm opacity-0 group-hover:opacity-100 transition-opacity duration-300 hidden md:flex flex-col sm:flex-row items-center justify-center gap-4 z-10">
      <a href={repoUrl} target="_blank" class="px-6 py-2 w-40 sm:w-48 text-center border border-text-muted text-text-muted hover:bg-text-muted hover:text-black font-mono text-sm transition-colors" aria-label={`View source code for ${title}`}>
        [ Source Code ]
      </a>
      {hasLiveUrl && (
        <a href={liveUrl} target="_blank" class="px-6 py-2 w-40 sm:w-48 text-center border border-binary-green text-binary-green hover:bg-binary-green hover:text-black font-mono text-sm transition-colors" aria-label={`View live site for ${title}`}>
          [ Live Site ]
        </a>
      )}
    </div>
  </div>
</article>
