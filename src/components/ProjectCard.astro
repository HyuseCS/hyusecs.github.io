---
export interface Props {
  title: string;
  date: string;
  description: string;
  tags: string[];
  repoUrl?: string;
  liveUrl?: string;
  className?: string;
  staggerClass?: string;
}

const { 
  title, 
  date, 
  description, 
  tags, 
  repoUrl = "#", 
  liveUrl = "#", 
  className = "",
  staggerClass = "stagger-1"
} = Astro.props;
---

<div class={`group relative flex flex-col justify-between border border-[#333] bg-[#111] p-5 sm:p-6 hover:border-[#27c93f] transition-all hover:-translate-y-1 animate-on-scroll ${staggerClass} overflow-hidden ${className}`}>
  <div>
    <div class="flex justify-between items-start mb-4">
      <h3 class="text-lg sm:text-xl font-bold text-white group-hover:text-[#27c93f] transition-colors">{title}</h3>
      <span class="text-[#888] text-xs shrink-0 ml-2 mt-1">{date}</span>
    </div>
    <p class="text-[#888] text-sm mb-6 leading-relaxed">
      {description}
    </p>
    <div class="flex flex-wrap gap-2 mb-6 md:mb-0">
      {tags.map(tag => (
        <span class="text-xs font-mono text-[#ffbd2e] bg-[#1e1e1e] px-2 py-1 rounded-sm">{tag}</span>
      ))}
    </div>
  </div>

  <!-- Mobile Action Buttons (Visible statically on touch/small screens) -->
  <div class="mt-auto flex flex-col sm:flex-row gap-3 md:hidden">
    <a href={repoUrl} target="_blank" class="px-4 py-2 w-full text-center border border-[#d4d4d4] text-[#d4d4d4] hover:bg-[#d4d4d4] hover:text-black font-mono text-xs sm:text-sm transition-colors">
      [ Source Code ]
    </a>
    <a href={liveUrl} target="_blank" class="px-4 py-2 w-full text-center border border-[#27c93f] text-[#27c93f] hover:bg-[#27c93f] hover:text-black font-mono text-xs sm:text-sm transition-colors">
      [ Live Site ]
    </a>
  </div>

  <!-- Desktop Hover Overlay Menu (Hidden on mobile) -->
  <div class="absolute inset-0 bg-[#0c0c0c]/90 backdrop-blur-sm opacity-0 group-hover:opacity-100 transition-opacity duration-300 hidden md:flex flex-col sm:flex-row items-center justify-center gap-4 z-10">
    <a href={repoUrl} target="_blank" class="px-6 py-2 w-40 sm:w-48 text-center border border-[#d4d4d4] text-[#d4d4d4] hover:bg-[#d4d4d4] hover:text-black font-mono text-sm transition-colors focus:outline-none focus:ring-2 focus:ring-[#27c93f]">
      [ Source Code ]
    </a>
    <a href={liveUrl} target="_blank" class="px-6 py-2 w-40 sm:w-48 text-center border border-[#27c93f] text-[#27c93f] hover:bg-[#27c93f] hover:text-black font-mono text-sm transition-colors focus:outline-none focus:ring-2 focus:ring-[#27c93f]">
      [ Live Site ]
    </a>
  </div>
</div>
