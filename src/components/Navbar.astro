---
import { getSystemConfig } from '../lib/firebase/config';

const config = await getSystemConfig();
const resumeUrl = config.resumeUrl;

// Dynamic Version Calculation (vAge.MonthsOld)
const birthDate = new Date('2004-03-03');
const now = new Date();

let age = now.getFullYear() - birthDate.getFullYear();
let monthsOld = now.getMonth() - birthDate.getMonth();

if (monthsOld < 0 || (monthsOld === 0 && now.getDate() < birthDate.getDate())) {
    age--;
    monthsOld = 12 + (now.getMonth() - birthDate.getMonth());
}

// Adjust monthsOld if current day is before birth day
if (now.getDate() < birthDate.getDate()) {
    monthsOld--;
}

// Ensure monthsOld isn't negative from the above subtraction
if (monthsOld < 0) monthsOld = 11;

const monthsOldStr = monthsOld.toString().padStart(2, '0');
const dynamicVersion = `v${age}.${monthsOldStr}`;
---

<nav class="fixed top-0 left-0 right-0 z-50 h-16 bg-obsidian/80 backdrop-blur-md border-b border-system-border">
  <div class="max-w-6xl mx-auto px-4 h-full flex items-center justify-between">
    <!-- Brand -->
    <a href="/" class="flex items-center gap-2 group">
      <div class="w-8 h-8 bg-binary-green flex items-center justify-center font-bold text-obsidian text-lg">
        H
      </div>
      <div class="flex flex-col">
        <span class="text-white font-bold text-sm tracking-tight group-hover:text-binary-green transition-colors">HyuseCS</span>
        <span class="nav-version-display text-text-dim text-[10px] font-mono leading-none uppercase">{dynamicVersion}</span>
      </div>
    </a>

    <!-- Desktop Nav -->
    <div class="hidden md:flex items-center gap-8">
      <div class="flex items-center gap-6">
        <a href="#about" class="text-text-muted hover:text-white text-xs font-mono transition-colors uppercase tracking-widest">About</a>
        <a href="#skills" class="text-text-muted hover:text-white text-xs font-mono transition-colors uppercase tracking-widest">Skills</a>
        <a href="#projects" class="text-text-muted hover:text-white text-xs font-mono transition-colors uppercase tracking-widest">Projects</a>
        <a href="#activity" class="text-text-muted hover:text-white text-xs font-mono transition-colors uppercase tracking-widest">Activity</a>
        <a href="#contact" class="text-text-muted hover:text-white text-xs font-mono transition-colors uppercase tracking-widest">Contact</a>
      </div>
      
      <div class="h-8 w-px bg-system-border"></div>
      
      <a href={resumeUrl} target="_blank" class="flex items-center gap-2 text-caution-yellow hover:text-white text-xs font-mono transition-colors">
        <span aria-hidden="true">📄</span> {resumeUrl.split('/').pop()}
      </a>
    </div>

    <!-- Mobile Toggle -->
    <button id="mobile-toggle" class="md:hidden text-white p-2" aria-label="Toggle menu">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />
      </svg>
    </button>
  </div>

  <!-- Mobile Drawer -->
  <div id="mobile-drawer" class="fixed inset-0 bg-obsidian z-[100] flex flex-col translate-x-full transition-transform duration-300 md:hidden">
    <div class="h-16 border-b border-system-border flex items-center justify-between px-4 bg-neutral-surface">
      <span class="text-binary-green font-mono text-xs uppercase tracking-widest">System Navigation</span>
      <button id="close-drawer" class="text-white p-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
    <div class="flex-grow flex flex-col justify-center items-center gap-8 p-8">
      <a href="#about" class="mobile-link text-white text-2xl font-bold uppercase tracking-tighter">./About</a>
      <a href="#skills" class="mobile-link text-white text-2xl font-bold uppercase tracking-tighter">./Skills</a>
      <a href="#projects" class="mobile-link text-white text-2xl font-bold uppercase tracking-tighter">./Projects</a>
      <a href="#activity" class="mobile-link text-white text-2xl font-bold uppercase tracking-tighter">./Activity</a>
      <a href="#contact" class="mobile-link text-white text-2xl font-bold uppercase tracking-tighter">./Contact</a>
      
      <div class="w-full h-px bg-system-border my-4"></div>
      
      <a href={resumeUrl} target="_blank" class="mobile-link flex items-center gap-3 text-caution-yellow text-lg font-mono">
        <span aria-hidden="true">📄</span> {resumeUrl.split('/').pop()}
      </a>
    </div>
    <div class="p-8 border-t border-system-border bg-neutral-surface text-[10px] font-mono text-text-dim flex justify-between">
      <span>SECURE_CONNECTION: TRUE</span>
      <span class="nav-version-display">{dynamicVersion}</span>
    </div>
  </div>
</nav>

<script>
  const mobileToggle = document.getElementById('mobile-toggle');
  const closeDrawer = document.getElementById('close-drawer');
  const mobileDrawer = document.getElementById('mobile-drawer');
  const mobileLinks = document.querySelectorAll('.mobile-link');

  function openMenu() {
    mobileDrawer?.classList.remove('translate-x-full');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    mobileDrawer?.classList.add('translate-x-full');
    document.body.style.overflow = '';
  }

  mobileToggle?.addEventListener('click', openMenu);
  closeDrawer?.addEventListener('click', closeMenu);
  mobileLinks.forEach(link => link.addEventListener('click', closeMenu));

  // Dynamic Version Update (Client-side)
  function updateVersion() {
    const versionSpans = document.querySelectorAll('.nav-version-display');
    const birthDate = new Date('2004-03-03');
    const now = new Date();
    
    let age = now.getFullYear() - birthDate.getFullYear();
    let monthsOld = now.getMonth() - birthDate.getMonth();

    if (monthsOld < 0 || (monthsOld === 0 && now.getDate() < birthDate.getDate())) {
        age--;
        monthsOld = 12 + (now.getMonth() - birthDate.getMonth());
    }

    if (now.getDate() < birthDate.getDate()) {
        monthsOld--;
    }

    if (monthsOld < 0) monthsOld = 11;

    const monthsOldStr = monthsOld.toString().padStart(2, '0');
    const versionString = `v${age}.${monthsOldStr}`;

    versionSpans.forEach(span => {
      span.textContent = versionString;
    });
  }

  // Initial update and periodic check (e.g., every hour)
  updateVersion();
  setInterval(updateVersion, 3600000);
</script>
