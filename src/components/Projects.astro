---
import ProjectCard from './ProjectCard.astro';

const projects = [
  {
    title: "JRJC Car Rental Booking",
    date: "Sep 2025",
    description: "Full-stack Developer (Remote). Developed the booking system's management panel, Live Dashboard, Car Management module, and the Website's Content Management System.",
    tags: ["NextJS", "Supabase", "Vercel"],
    repoUrl: "https://github.com/seodowa/JRJC",
    liveUrl: "https://jrjc.vercel.app/",
    className: "",
    staggerClass: "stagger-1"
  },
  {
    title: "Happsay",
    date: "Jan 2025",
    description: "Frontend Developer & QA (Remote). Contributed to assessing quality and fixing last-minute UI/UX bugs in the frontend found through rigorous quality assurance testing.",
    tags: ["React", "Django REST"],
    repoUrl: "https://github.com/Aguynamedkent7/Happsay_frontend",
    liveUrl: "https://happsay-frontend.vercel.app",
    className: "",
    staggerClass: "stagger-2"
  },
  {
    title: "Library Management & QR Scanner",
    date: "May 2025",
    description: "Full-stack Developer. Developed the webcam QR scanning and recognition software natively using JavaFX and successfully integrated it into a local PostgreSQL database for efficient student record fetching.",
    tags: ["Java", "PostgreSQL"],
    repoUrl: "https://github.com/Aguynamedkent7/Library_Management_System",
    liveUrl: "#",
    className: "md:col-span-2 max-w-2xl w-full mx-auto",
    staggerClass: "stagger-3"
  }
];
---

<section id="projects" class="min-h-screen snap-start scroll-mt-14 flex flex-col justify-center border-b border-[#333] bg-[#0c0c0c]">
  <div class="p-5 md:p-8 py-12 md:py-16 flex-grow flex flex-col justify-center items-center">
    <div class="max-w-4xl w-full">
      <div class="flex gap-2 text-[#27c93f] mb-6 md:mb-8 text-sm sm:text-base animate-on-scroll">
        <span class="font-bold">❯</span>
        <span class="text-[#d4d4d4] break-all">ls -la /opt/deployed_projects</span>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8 pl-0 sm:pl-4">
        {projects.map((p) => (
          <ProjectCard 
            title={p.title}
            date={p.date}
            description={p.description}
            tags={p.tags}
            repoUrl={p.repoUrl}
            liveUrl={p.liveUrl}
            className={p.className}
            staggerClass={p.staggerClass}
          />
        ))}
      </div>
      
    </div>
  </div>
</section>