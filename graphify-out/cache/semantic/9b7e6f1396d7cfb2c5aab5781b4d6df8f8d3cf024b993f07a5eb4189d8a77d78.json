{"nodes": [{"id": "hyusecs_github_io_design", "label": "Design System Specification", "file_type": "document", "source_file": "DESIGN.md"}, {"id": "concept_the_system_monitor", "label": "The System Monitor", "file_type": "rationale", "source_file": "DESIGN.md", "rationale": "A dark, tactile environment where code, status, and telemetry are primary citizens. Rejects 'AI slop' aesthetics in favor of rigid grids and terminal prompts."}, {"id": "concept_terminal_first", "label": "Terminal-First Aesthetic", "file_type": "rationale", "source_file": "DESIGN.md", "rationale": "Monospaced typography and command-line affordances drive the interface. Uses prefixes like \u276f, ./, or // to indicate command intent."}, {"id": "concept_tonal_layering", "label": "Tonal Layering", "file_type": "rationale", "source_file": "DESIGN.md", "rationale": "Depth is conveyed through background shifts and border treatments instead of drop shadows. Surfaces move from Obsidian base to Layer 1 and Layer 2."}], "edges": [{"source": "hyusecs_github_io_design", "target": "concept_the_system_monitor", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "DESIGN.md"}, {"source": "concept_the_system_monitor", "target": "layouts_layout", "relation": "rationale_for", "confidence": "INFERRED", "confidence_score": 0.9, "source_file": "DESIGN.md"}, {"source": "concept_terminal_first", "target": "hyusecs_github_io_design", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "DESIGN.md"}, {"source": "concept_high_craft", "target": "hyusecs_github_io_design", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "DESIGN.md"}, {"source": "concept_the_machine_aesthetic", "target": "hyusecs_github_io_design", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "DESIGN.md"}, {"source": "concept_tonal_layering", "targ