    {
      "id": "concept_the_system_monitor",
      "label": "The System Monitor",
      "file_type": "rationale",
      "source_file": "DESIGN.md",
      "rationale": "A dark, tactile environment where code, status, and telemetry are primary citizens. Rejects 'AI slop' aesthetics in favor of rigid grids and terminal prompts."
    },
    {
      "id": "concept_terminal_first",
      "label": "Terminal-First Aesthetic",
      "file_type": "rationale",
      "source_file": "DESIGN.md",
      "rationale": "Monospaced typography and command-line affordances drive the interface. Uses prefixes like ❯, ./, or // to indicate command intent."
    },
    {
      "id": "concept_high_craft",
      "label": "High-Craft Design",
      "file_type": "rationale",
      "source_file": "PRODUCT.md",
      "rationale": "Obsessive attention to detail in animations, telemetry data, and system-level status."
    },
    {
      "id": "concept_show_dont_tell",
      "label": "Show, Don't Tell Principle",
      "file_type": "rationale",
      "source_file": "PRODUCT.md",
      "rationale": "Use live telemetry and working code patterns (typewriters, terminal logs) to prove expertise rather than static claims."
    },
    {
      "id": "concept_the_machine_aesthetic",
      "label": "The Machine Aesthetic",
      "file_type": "rationale",
      "source_file": "PRODUCT.md",
      "rationale": "Embrace the raw materials of computing—grids, terminal prompts, and status daemons."
    },
    {
      "id": "concept_tonal_layering",
      "label": "Tonal Layering",
      "file_type": "rationale",
      "source_file": "DESIGN.md",
      "rationale": "Depth is conveyed through background shifts and border treatments instead of drop shadows. Surfaces move from Obsidian base to Layer 1 and Layer 2."
    }
  ],
